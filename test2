    async function executeLocationSearch() {
      const input = document.getElementById("location-search-input");
      const err = document.getElementById("location-search-error");
      const btn = document.getElementById("location-search-btn");
      const candidates = document.getElementById("location-search-candidates");
      const query = input.value.trim();
      if (!query) return;

      btn.textContent = "検索中...";
      btn.disabled = true;
      err.style.display = "none";
      candidates.style.display = "none";
      candidates.innerHTML = "";

      try {
        // 国土地理院（地名・住所）とHeartRails（駅名）を並列で叩く
        const [gsiRes, stationRes] = await Promise.allSettled([
          fetch(`https://msearch.gsi.go.jp/address-search/AddressSearch?q=${encodeURIComponent(query)}`),
          fetch(`https://express.heartrails.com/api/json?method=getStations&name=${encodeURIComponent(query.replace(/駅$/, ''))}`)
        ]);

        btn.textContent = "検索";
        btn.disabled = false;

        // HeartRailsの結果をパース（駅名重複除去）
        const stationItems = [];
        if (stationRes.status === "fulfilled") {
          const data = await stationRes.value.json().catch(() => ({}));
          const stations = data?.response?.station || [];
          const seen = new Set();
          stations.forEach(s => {
            const key = `${s.name}_${s.prefecture}`;
            if (!seen.has(key)) {
              seen.add(key);
              stationItems.push({
                name: `${s.name}駅（${s.prefecture}・${s.line}）`,
                lat: parseFloat(s.y),
                lng: parseFloat(s.x),
                type: "station"
              });
            }
          });
          stationItems.splice(4);
        }

        // 国土地理院の結果をパース（dataSource:1のみ表示）
        const gsiItems = [];
        const gsiTransport = []; // 駅・IC・JCT（駅・インターセクション用）
        const gsiAddress = [];   // 地名・住所セクション用
        if (gsiRes.status === "fulfilled") {
          const data = await gsiRes.value.json().catch(() => []);
          // HeartRailsの駅名セット（重複排除用）
          const stationNames = new Set(stationItems.map(s => s.name.replace(/駅（.*）$/, '') + '駅'));
          // 都道府県コード変換表（addressCodeの先頭1-2桁）
          const prefMap = {
            "1":"北海道","2":"青森県","3":"岩手県","4":"宮城県","5":"秋田県","6":"山形県","7":"福島県",
            "8":"茨城県","9":"栃木県","10":"群馬県","11":"埼玉県","12":"千葉県","13":"東京都","14":"神奈川県",
            "15":"新潟県","16":"富山県","17":"石川県","18":"福井県","19":"山梨県","20":"長野県",
            "21":"岐阜県","22":"静岡県","23":"愛知県","24":"三重県","25":"滋賀県","26":"京都府",
            "27":"大阪府","28":"兵庫県","29":"奈良県","30":"和歌山県","31":"鳥取県","32":"島根県",
            "33":"岡山県","34":"広島県","35":"山口県","36":"徳島県","37":"香川県","38":"愛媛県","39":"高知県",
            "40":"福岡県","41":"佐賀県","42":"長崎県","43":"熊本県","44":"大分県","45":"宮崎県",
            "46":"鹿児島県","47":"沖縄県"
          };
          const getPref = (code) => {
            if (!code) return "";
            const s = String(code).replace(/^0+/, '') || "0";
            // 4桁以下は先頭1桁、5桁以上は先頭2桁で判定
            const key = s.length <= 4 ? s.slice(0, 1) : s.slice(0, 2);
            return prefMap[key] || "";
          };
          const gsiSeenStations = new Set();

          (data || []).forEach(item => {
            const title = item.properties.title;
            const ds = item.properties.dataSource ?? "";

            if (ds === "1") {
              // 駅・IC・JCTのみ、都道府県名を付加
              const isStation = title.endsWith('駅');
              const isIC = title.endsWith('ＩＣ') || title.endsWith('IC');
              const isJCT = title.endsWith('ＪＣＴ') || title.endsWith('JCT');
              if (!isStation && !isIC && !isJCT) return;
              const pref = getPref(item.properties.addressCode);
              const displayName = pref ? `${title}（${pref}）` : title;
              if (isStation && stationNames.has(title)) return;
              if (isStation) {
                if (gsiSeenStations.has(title)) return;
                gsiSeenStations.add(title);
              }
              gsiTransport.push({ name: displayName, lat: item.geometry.coordinates[1], lng: item.geometry.coordinates[0], type: "address", isStation });
            } else if (ds === "" || ds === "3") {
              // 地名・住所セクション
              console.log('[GSI address]', ds, title);
              gsiAddress.push({ name: title, lat: item.geometry.coordinates[1], lng: item.geometry.coordinates[0], type: "address" });
            }
            // dataSource:"5" は非表示
          });
          // transportは駅を先に、IC/JCTを後に
          gsiTransport.sort((a, b) => (b.isStation ? 1 : 0) - (a.isStation ? 1 : 0));
          gsiItems.push(...gsiTransport, ...gsiAddress);
        }

        if (!stationItems.length && !gsiItems.length) {
          err.textContent = "地点が見つかりませんでした。別の名前で試してください。";
          err.style.display = "block";
          return;
        }

        const stationIcon = `<svg width="14" height="14" viewBox="0 0 24 24" fill="#3b82f6" style="flex-shrink:0;"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/></svg>`;
        const addressIcon = `<svg width="14" height="14" viewBox="0 0 24 24" fill="#9ca3af" style="flex-shrink:0;"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>`;

        const renderItem = (item, isLast) => `<div onclick="applyLocationPoint(${item.lat}, ${item.lng}, '${item.name.replace(/'/g, "&#39;")}')"
            style="padding:12px 14px;cursor:pointer;${isLast ? '' : 'border-bottom:1px solid #f3f4f6;'}display:flex;align-items:center;gap:10px;background:white;"
            onmouseover="this.style.background='#f9fafb'" onmouseout="this.style.background='white'">
            ${item.type === "station" ? stationIcon : addressIcon}
            <div style="font-size:14px;font-weight:500;color:#111827;">${item.name}</div>
          </div>`;

        candidates.style.display = "block";

        let html = "";
        // 駅・インターセクション（HeartRails + GSI dataSource:1）
        const transportItems = [...stationItems, ...gsiTransport];
        if (transportItems.length) {
          html += `<div style="padding:6px 14px;font-size:11px;color:#9ca3af;background:#f9fafb;border-bottom:1px solid #f3f4f6;">駅・インター</div>`;
          html += transportItems.map((item, i) => renderItem(item, false)).join("");
        }
        // 地名・住所セクション（GSI dataSource:"" + "3"）
        if (gsiAddress.length) {
          html += `<div style="padding:6px 14px;font-size:11px;color:#9ca3af;background:#f9fafb;border-bottom:1px solid #f3f4f6;${transportItems.length ? 'border-top:1px solid #e5e7eb;' : ''}">地名・住所</div>`;
          html += gsiAddress.map((item, i) => renderItem(item, i === gsiAddress.length - 1)).join("");
        }
        candidates.innerHTML = html;
      } catch(e) {
        err.textContent = "通信エラーが発生しました。";
        err.style.display = "block";
        btn.textContent = "検索";
        btn.disabled = false;
      }
    }

    // 下部バーの「今から」ボタン用（常にオン）
    async function handleNearbyMode() {
      // 常にオンにする（トグルではなく）
      // 既にオンの場合は何もしない
      if (nearbyMode) {
        return;
      }
      
      // オンにする - 位置情報取得
      if (!navigator.geolocation) {
        await showCustomAlert('お使いのブラウザは位置情報に対応していません。');
        return;
      }
      
      isRequestingLocation = true;
      
      navigator.geolocation.getCurrentPosition(
        (position) => {
          // 取得中にOFFにされた場合は処理しない
          if (!isRequestingLocation) {
            return;
          }
          
          isRequestingLocation = false;
          
          userLocation = {
            lat: position.coords.latitude,
            lng: position.coords.longitude
          };
          
          nearbyMode = true;
          showOpenOnly = true;
          document.getElementById('btn-nearby').classList.add('active');
          document.getElementById('btn-open-toggle').classList.add('active');
          document.getElementById('list-btn-nearby')?.classList.add('active');
          document.getElementById('list-btn-open-toggle')?.classList.add('active');
          
          // 地図に青い点を表示
          if (userMarker) {
            userMarker.remove();
          }
          
          const userIcon = L.divIcon({
            className: 'user-marker',
            html: '<div style="width:16px;height:16px;border-radius:50%;background:#3b82f6;border:3px solid white;box-shadow:0 2px 8px rgba(0,0,0,0.3);"></div>',
            iconSize: [16, 16],
            iconAnchor: [8, 8]
          });
          
          userMarker = L.marker([userLocation.lat, userLocation.lng], { icon: userIcon, zIndexOffset: 1000 }).addTo(map);
          
          // 地図を現在地中心に
          map.setView([userLocation.lat, userLocation.lng], Math.max(map.getZoom(), 13), { animate: true });
          
          renderShopList();
          updateMarkers();
          renderFeedTab();
        },
        async (error) => {
          isRequestingLocation = false;
          
          let errorMessage = '位置情報の取得に失敗しました。\n\n';
          
          if (error.code === 1) {
            // PERMISSION_DENIED
            errorMessage += '原因: 位置情報の利用が許可されていません。\n\n';
            errorMessage += '対処法:\n';
            errorMessage += '1. ブラウザのアドレスバー左側のアイコンをタップ\n';
            errorMessage += '2. 「位置情報」の設定を「許可」に変更\n';
            errorMessage += '3. ページをリロード';
          } else if (error.code === 2) {
            // POSITION_UNAVAILABLE
            errorMessage += '原因: 位置情報を取得できませんでした。\n\n';
            errorMessage += '対処法:\n';
            errorMessage += '1. デバイスの位置情報サービスがオンになっているか確認\n';
            errorMessage += '2. Wi-Fiまたはモバイルデータ通信がオンか確認';
          } else if (error.code === 3) {
            // TIMEOUT
            errorMessage += '原因: 位置情報の取得がタイムアウトしました。\n\n';
            errorMessage += '対処法: もう一度お試しください。';
          }
          
          await showCustomAlert(errorMessage);
          console.error('Geolocation error:', error.message || String(error));
        }
      );
    }
    
