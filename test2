    function getLineageRootId(id) {
      let cur = shops.find(s => s.id === id);
      const seen = new Set();
      while (cur && cur.parent) {
        if (seen.has(cur.id)) break;
        seen.add(cur.id);
        cur = shops.find(s => s.id === cur.parent);
      }
      return cur ? cur.id : null;
    }
    
    // 指定された祖先を持つか判定
    function hasAncestor(shopId, ancestorId) {
      let cur = shops.find(s => s.id === shopId);
      const seen = new Set();
      while (cur) {
        if (cur.id === ancestorId) return true;
        if (!cur.parent || seen.has(cur.id)) break;
        seen.add(cur.id);
        cur = shops.find(s => s.id === cur.parent);
      }
      return false;
    }
    
