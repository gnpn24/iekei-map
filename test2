      // クリックでポップアップ表示
      wrapper.addEventListener('click', (e) => {
        e.stopPropagation();
        if (activeGroupPopup && activeGroupPopup !== popup) {
          activeGroupPopup.classList.remove('visible');
        }
        popup.classList.toggle('visible');
        activeGroupPopup = popup.classList.contains('visible') ? popup : null;

        // ポップアップ位置調整（表示後に実際のサイズを取得）
        if (popup.classList.contains('visible')) {
          const safeTop = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--sat') || '0') + 60;
          const margin = 8;
          const cx = e.clientX;
          const cy = e.clientY;
          const popupW = popup.offsetWidth;
          const popupH = popup.offsetHeight;

          // 左右：右に収まれば右、収まらなければ左
          let left = cx + margin;
          if (left + popupW > window.innerWidth - margin) {
            left = cx - popupW - margin;
          }
          // さらに画面左にはみ出す場合は左端に寄せる
          left = Math.max(margin, left);

          // 上下：利用可能な高さを計算してmax-heightを設定
          let top = cy + margin;
          const safeBottom = 120; // 下部バー分の余白
          const availableBottom = window.innerHeight - safeBottom - top;
          const availableTop = cy - margin;
          
          if (availableBottom >= availableTop) {
            // 下に表示
            popup.style.maxHeight = `${availableBottom}px`;
          } else {
            // 上に表示：ノードの真上、はみ出す場合は上端に寄せる
            popup.style.maxHeight = `${availableTop}px`;
            top = Math.max(margin, cy - popup.offsetHeight - margin);
          }
          top = Math.max(safeTop, top);

          popup.style.left = `${left}px`;
          popup.style.top = `${top}px`;
        }
      });

      // ポップアップアイテムクリック
      popup.querySelectorAll('.lineage-group-popup-item').forEach(item => {
        item.addEventListener('click', (e) => {
          e.stopPropagation();
          showShopDetail(item.dataset.shopid);
          popup.classList.remove('visible');
          activeGroupPopup = null;
        });
      });

      return wrapper;
    }

    function createLineageNode(shop, colorClass, sectionId, useGroupName = false) {
      // ダミーノード（name === "ダミー"）は透明スペーサーとして描画
      if (shop.name === 'ダミー') {
        const node = document.createElement('div');
        node.className = 'lineage-node dummy';
        node.dataset.id = shop.id;
        node.dataset.dummy = '1';
        return node;
      }

      // 閉店している店舗: 営業時間がnullまたは全日休み、または店名に【閉店】が含まれる
      const isClosed = !shop.openingHours ||
                       (shop.openingHours &&
                        Object.keys(shop.openingHours).length === 0) ||
                       shop.name.includes('【閉店】');
      
      // 独立セクションへのジャンプリンク生成
      let jumpLink = '';
      const isInOwnSection = (
        (sectionId === '王道家系' && shop.id === 'oudouya') ||
        (sectionId === '王道家系（王道乃印）' && shop.id === 'oudouya') ||
        (sectionId === '本牧家系' && shop.id === 'honmokuya') ||
        (sectionId === '六角家系' && shop.id === 'rokkakuya') ||
        (sectionId === '武蔵家系' && shop.id === 'musashiya')
      );
      
      if (!isInOwnSection) {
        if (shop.id === 'oudouya') {
          jumpLink = `<span class="lineage-jump" data-target="王道家系" style="font-size:10px;margin-left:4px;color:#000000;cursor:pointer;user-select:none;">[→王道家系]</span>`;
        } else if (shop.id === 'honmokuya') {
          jumpLink = `<span class="lineage-jump" data-target="本牧家系" style="font-size:10px;margin-left:4px;color:#000000;cursor:pointer;user-select:none;">[→本牧家系]</span>`;
        } else if (shop.id === 'rokkakuya') {
          jumpLink = `<span class="lineage-jump" data-target="六角家系" style="font-size:10px;margin-left:4px;color:#000000;cursor:pointer;user-select:none;">[→六角家系]</span>`;
        } else if (shop.id === 'musashiya') {
          jumpLink = `<span class="lineage-jump" data-target="武蔵家系" style="font-size:10px;margin-left:4px;color:#000000;cursor:pointer;user-select:none;">[→武蔵家系]</span>`;
        }
      }
      
      // 表示名の決定
      let displayName = shop.name;
      let displayNameHtml = escapeHtml(displayName);
      if (useGroupName && shop.group) {
        const rawGroupName = (GROUP_LABELS[shop.group] || shop.group).replace(/\\n/g, '\n');
        displayNameHtml = escapeHtml(rawGroupName).replace(/\n/g, '<br>');
      }
      
      // 色分け
      let nodeColorClass = colorClass;
      
      // 閉店店舗は常にグレー
      if (isClosed) {
        nodeColorClass = 'closed';
      }
      // 王道家系セクション内: 王道家（王道乃印）は薄い黄色
      else if (colorClass === 'oud' && shop.category === '王道家（王道乃印）') {
        nodeColorClass = 'oud-light';
      }
      // 吉村家系セクション内: 吉村家（直系以外）は薄い赤
      else if (colorClass === 'yosh' && shop.category === '吉村家（直系以外）') {
        nodeColorClass = 'yosh-light';
      }
      
      const node = document.createElement('div');
      node.className = `lineage-node g-${nodeColorClass}`;
      node.dataset.id = shop.id;
      node.innerHTML = `
        <div class="lineage-node-name">${displayNameHtml}${jumpLink}</div>
        <div class="lineage-node-meta">${escapeHtml(shop.area || '')}</div>
      `;
      
      // ジャンプリンクのクリックイベント
      if (jumpLink) {
        const linkEl = node.querySelector('.lineage-jump');
        if (linkEl) {
          linkEl.addEventListener('click', (e) => {
            e.stopPropagation();
            const targetName = linkEl.getAttribute('data-target');
            const targetSection = document.getElementById(`lineage-section-${targetName}`);
            if (targetSection) {
              // 検索バーの高さを考慮してオフセット
              const searchWrap = document.getElementById('lineage-search-wrap');
              const headerHeight = searchWrap ? searchWrap.getBoundingClientRect().height + 32 : 120;
              const rect = targetSection.getBoundingClientRect();
              const scrollParent = targetSection.closest('.tab-content') || window;
              if (scrollParent === window) {
                window.scrollBy({ top: rect.top - headerHeight, behavior: 'smooth' });
              } else {
                scrollParent.scrollBy({ top: rect.top - scrollParent.getBoundingClientRect().top - headerHeight, behavior: 'smooth' });
              }
            }
          });
        }
      }
      
      const noCoords = !shop.lat || !shop.lng;
      const isClosedShop = shop.name.includes('【閉店】');
      if (noCoords && !isClosedShop) {
        node.style.cursor = 'default';
      } else {
        node.addEventListener('click', () => selectLineageNode(shop.id));
      }
      return node;
    }
    
    function drawLineageWires(section, items, dummyItems, levels, order) {
      const svg = section.querySelector('.lineage-wires');
      const box = section.querySelector('.lineage-section-box');
      const nodes = section.querySelectorAll('.lineage-node, .lineage-node-group');
      
      // SVGのサイズを設定
      const boxRect = box.getBoundingClientRect();
      svg.setAttribute('width', box.scrollWidth);
      svg.setAttribute('height', box.scrollHeight);
      svg.style.width = box.scrollWidth + 'px';
      svg.style.height = box.scrollHeight + 'px';
      
      const positions = new Map();
      nodes.forEach(node => {
        const rect = node.getBoundingClientRect();
        positions.set(node.dataset.id, {
          x: rect.left - boxRect.left + box.scrollLeft + rect.width / 2,
          y: rect.top - boxRect.top + box.scrollTop + rect.height / 2
        });
      });
      
      const paths = [];
      dummyItems.forEach(shop => {
        if (!shop.parent) return;
        // 横ダミーへの線は引かない
        if (shop.id && shop.id.startsWith('__dummy_yoko_')) return;
        // 縦下ダミー自身への線も引かない
        if (shop.id && shop.id.startsWith('__dummy_tate_silent_')) return;

        const childPos = positions.get(shop.id);

        // 縦下ダミーを親に持つ場合：ダミーを飛ばして実祖先を親にし、折り曲げY座標はダミーの位置を使う
        let parentId = shop.parent;
        let bendY = null;
        while (parentId && parentId.startsWith('__dummy_tate_silent_')) {
          const dummyPos = positions.get(parentId);
          if (dummyPos && bendY === null) bendY = dummyPos.y;
          const dummyShop = dummyItems.find(s => s.id === parentId);
          parentId = dummyShop ? dummyShop.parent : null;
        }

        const parentPos = positions.get(parentId);
        if (!childPos || !parentPos) return;

        if (shop.position === '系列') {
          // 横線でつなぐ（同じ段）
          paths.push(`M ${parentPos.x} ${parentPos.y} L ${childPos.x} ${childPos.y}`);
        } else if (bendY !== null) {
          // 縦下ダミーの高さで折り曲げ（線は引くがダミーノードへの線はなし）
          paths.push(`M ${parentPos.x} ${parentPos.y} L ${parentPos.x} ${bendY} L ${childPos.x} ${bendY} L ${childPos.x} ${childPos.y}`);
        } else {
          const midY = (parentPos.y + childPos.y) / 2;
          paths.push(`M ${parentPos.x} ${parentPos.y} L ${parentPos.x} ${midY} L ${childPos.x} ${midY} L ${childPos.x} ${childPos.y}`);
        }
      });
      
      svg.innerHTML = paths.map(d => `<path class="lineage-wire" d="${d}"/>`).join('');
      
      console.log('Wires drawn:', paths.length, 'paths');
    }
    
    function computeLineageLevels(items, roots) {
      const children = new Map();
      items.forEach(s => {
        if (!s.parent) return;
        if (!children.has(s.parent)) children.set(s.parent, []);
        children.get(s.parent).push(s.id);
      });
      
      const levels = new Map();
      const q = roots.map(r => ({ id: r.id, level: 0 }));
      roots.forEach(r => levels.set(r.id, 0));
      
      while (q.length) {
        const cur = q.shift();
        const kids = children.get(cur.id) || [];
        kids.forEach(kid => {
          const nextLevel = cur.level + 1;
          if (!levels.has(kid) || nextLevel < levels.get(kid)) {
            levels.set(kid, nextLevel);
            q.push({ id: kid, level: nextLevel });
          }
        });
      }
      
      items.forEach(s => {
        if (!levels.has(s.id)) levels.set(s.id, 0);
      });
      
      return levels;
    }
    
    function buildLineageOrder(items, roots) {
      const children = new Map();
      items.forEach(s => {
        if (!s.parent) return;
        if (!children.has(s.parent)) children.set(s.parent, []);
        children.get(s.parent).push(s.id);
      });
      
      const order = [];
      const q = roots.map(r => r.id);
      const seen = new Set();
      
      while (q.length) {
        const id = q.shift();
        if (seen.has(id)) continue;
        seen.add(id);
        order.push(id);
        
        // JSON順のまま（ソートしない）
        const kids = children.get(id) || [];
        q.push(...kids);
      }
      
      items.forEach(s => {
        if (!seen.has(s.id)) order.push(s.id);
      });
      
      return order;
    }
    
    function initLineageUI() {
      const input = document.getElementById('lineage-search');
      const sug = document.getElementById('lineage-suggestions');
      const info = document.getElementById('lineage-info');
      const infoTitle = document.getElementById('lineage-info-title');
      const infoSub = document.getElementById('lineage-info-sub');
      const resetBtn = document.getElementById('lineage-reset-btn');
      
      if (!input || !sug) return;
      
      // 検索
      function renderLineageSuggestions(list) {
        if (!list.length) {
          sug.style.display = 'none';
          sug.innerHTML = '';
          return;
        }
        
        sug.innerHTML = list.map(s => {
          return `
            <div class="lineage-sitem" data-id="${s.id}">
              <div class="lineage-smain">
                <div class="lineage-sname">${escapeHtml(s.name)}</div>
                <div class="lineage-smeta">${escapeHtml(s.area || '')}</div>
              </div>
            </div>
          `;
        }).join('');
        sug.style.display = 'block';
      }
      
      function searchLineage(q) {
        const nq = q.trim().toLowerCase().replace(/[\s　]+/g, '');
        if (!nq) return [];
        
        const exact = shops.filter(s =>
          s.name.toLowerCase() === nq ||
          (s.nameHiragana && s.nameHiragana === nq)
        );
        if (exact.length) return exact;
        
        return shops.filter(s =>
          s.name.toLowerCase().includes(nq) ||
          (s.nameHiragana && s.nameHiragana.includes(nq)) ||
          (s.area && s.area.toLowerCase().includes(nq))
        ).slice(0, 12);
      }
      
      input.addEventListener('input', () => {
        const result = searchLineage(input.value);
        renderLineageSuggestions(result);
      });
      
      sug.addEventListener('click', (e) => {
        const item = e.target.closest('.lineage-sitem');
        if (!item) return;
        const id = item.getAttribute('data-id');
        const shop = shops.find(s => s.id === id);
        if (!shop) return;
        
        input.value = shop.name;
        sug.style.display = 'none';
        selectLineageNode(id);
        
        // ノードまでスクロール（グループノード対応）
        let node = document.querySelector(`.lineage-node[data-id="${id}"]`);
        let isGroupNode = false;
        if (!node) {
          const targetShop = shops.find(s => s.id === id);
          if (targetShop && targetShop.group) {
            const groupShops = shops.filter(s => s.group === targetShop.group);
            for (const gs of groupShops) {
              node = document.querySelector(`.lineage-node-group[data-id="${gs.id}"]`);
              if (node) { isGroupNode = true; break; }
            }
          }
        }
        if (node) {
          node.scrollIntoView({ behavior: 'smooth', block: 'center', inline: 'center' });
          if (isGroupNode) {
            // スクロール完了後にポップアップを開く
            setTimeout(() => {
              const rect = node.getBoundingClientRect();
              const cx = rect.left + rect.width / 2;
              const cy = rect.top + rect.height / 2;
              node.dispatchEvent(new MouseEvent('click', { bubbles: true, clientX: cx, clientY: cy }));
            }, 500);
          }
        }
      });
      
      document.addEventListener('click', (e) => {
        if (e.target.closest('#lineage-search-wrap')) return;
        sug.style.display = 'none';
      });
      
      if (resetBtn) {
        resetBtn.addEventListener('click', () => {
          document.querySelectorAll('.lineage-node.selected').forEach(n => {
            n.classList.remove('selected');
          });
          if (infoTitle) infoTitle.textContent = '店をタップすると情報が出ます';
          if (infoSub) infoSub.textContent = '検索からもジャンプできます';
          
          // 詳細画面ボタンを非表示
          const detailBtn = document.getElementById('lineage-detail-btn');
          if (detailBtn) detailBtn.style.display = 'none';
        });
      }
      
      // ズーム機能
      const zoomOutBtn = document.getElementById('lineage-zoom-out');
      const zoomInBtn = document.getElementById('lineage-zoom-in');
      const sectionsEl = document.getElementById('lineage-sections');
      let currentScale = 0.7; // デフォルト70%
      
      if (zoomOutBtn && zoomInBtn && sectionsEl) {
        // 縮小ボタン
        zoomOutBtn.addEventListener('click', () => {
          if (currentScale > 0.5) {
            currentScale -= 0.1;
            currentScale = Math.round(currentScale * 10) / 10; // 丸め誤差対策
            applyZoom();
          }
        });
        
        // 拡大ボタン
        zoomInBtn.addEventListener('click', () => {
          if (currentScale < 1.0) {
            currentScale += 0.1;
            currentScale = Math.round(currentScale * 10) / 10; // 丸め誤差対策
            applyZoom();
          }
        });
        
        function applyZoom() {
          // 一時的にtransformをリセットして実際の高さを取得（visibility:hiddenで見えないようにする）
          sectionsEl.style.visibility = 'hidden';
          sectionsEl.style.transform = 'scale(1)';
          sectionsEl.style.width = '100%';
          const actualHeight = sectionsEl.scrollHeight;
          
          // スケールを適用
          sectionsEl.style.transform = `scale(${currentScale})`;
          sectionsEl.style.transformOrigin = 'top left';
          sectionsEl.style.width = `${100 / currentScale}%`;
          sectionsEl.style.height = `${actualHeight * currentScale}px`;
          sectionsEl.style.visibility = 'visible';
          
          // ボタンの状態更新
          zoomOutBtn.disabled = currentScale <= 0.5;
          zoomInBtn.disabled = currentScale >= 1.0;
        }
        
        // 線描画はsetTimeout(0)で非同期に走るため、それより後に実行する必要がある。
        // visibility:hiddenで初期フラッシュ（scale(1)が一瞬見える）を防ぐ。
        sectionsEl.style.visibility = 'hidden';
        setTimeout(() => {
          applyZoom();
        }, 50);
        
        // グローバルに公開
        window.applyLineageZoom = applyZoom;
      }
    }
    
