    async function handleAvatarFileSelect(event, containerId) {
      const file = event.target.files[0];
      if (!file) return;
      if (!supabaseClient || !currentUser) {
        await showCustomAlert('ログインが必要です');
        return;
      }
      const container = document.getElementById(containerId);
      const statusEl = container?.parentElement.querySelector('.avatar-upload-status');
      if (statusEl) statusEl.textContent = 'アップロード中...';
      try {
        const blob = await compressAvatarImage(file);
        const path = `${currentUser.id}/avatar.jpg`;
        const { error: uploadError } = await supabaseClient.storage
          .from('avatars')
          .upload(path, blob, { upsert: true, contentType: 'image/jpeg' });
        if (uploadError) throw uploadError;
        const { data: urlData } = supabaseClient.storage.from('avatars').getPublicUrl(path);
        const finalUrl = `${urlData.publicUrl}?t=${Date.now()}`; // キャッシュ回避
        renderIconPicker(containerId, finalUrl);
        if (statusEl) statusEl.textContent = '画像を設定しました';
      } catch (e) {
        console.error('アバター画像アップロードエラー:', e);
        if (statusEl) statusEl.textContent = '';
        await showCustomAlert('画像のアップロードに失敗しました。もう一度お試しください。');
      }
    }

    // アバター画像を正方形にクロップ＆圧縮してBlobを返す
    function compressAvatarImage(file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = (e) => {
          const img = new Image();
          img.onload = () => {
            const SIZE = 256;
            const minSide = Math.min(img.width, img.height);
            const sx = (img.width - minSide) / 2;
            const sy = (img.height - minSide) / 2;
            const canvas = document.createElement('canvas');
            canvas.width = SIZE;
            canvas.height = SIZE;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(img, sx, sy, minSide, minSide, 0, 0, SIZE, SIZE);
            canvas.toBlob((blob) => {
              if (blob) resolve(blob); else reject(new Error('画像の処理に失敗しました'));
            }, 'image/jpeg', 0.8);
          };
          img.onerror = () => reject(new Error('画像の読み込みに失敗しました'));
          img.src = e.target.result;
        };
        reader.onerror = () => reject(new Error('ファイルの読み込みに失敗しました'));
        reader.readAsDataURL(file);
      });
    }

