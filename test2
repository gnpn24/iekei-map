    // Utility Functions
    
    function parseHHMM(hhmm) {
      const [h, m] = hhmm.split(':').map(Number);
      return h * 60 + m;
    }
    
    function getDayKey(date = new Date()) {
      const d = date.getDay(); // 0 Sun ... 6 Sat
      return ['sun','mon','tue','wed','thu','fri','sat'][d];
    }
    
    /**
     * 営業中かどうかを判定
     * openingHours: { mon:{times:[{start,end},...]}, ... }
     * 24hは start:"00:00", end:"24:00" 前提
     */
    function isOpenNow(openingHours, now = new Date()) {
      if (!openingHours) return false;

      const dayKey = getDayKey(now);
      const yesterdayKey = getDayKey(new Date(now.getTime() - 24*60*60*1000));

      const nowMin = now.getHours() * 60 + now.getMinutes();

      // 今日の枠 + 「昨日からの深夜またぎ枠」を見る
      const todayTimes = openingHours[dayKey]?.times || [];
      const yTimes = openingHours[yesterdayKey]?.times || [];

      // 今日枠判定
      for (const t of todayTimes) {
        const s = parseHHMM(t.start);
        const e = parseHHMM(t.end);

        if (t.start === "00:00" && t.end === "24:00") return true;

        if (e > s) {
          // 通常
          if (nowMin >= s && nowMin < e) return true;
        } else if (e < s) {
          // 深夜またぎ（例 10:00-07:00 → 今日の 10:00〜24:00 部分）
          if (nowMin >= s) return true;
        }
      }

      // 昨日枠の深夜またぎ判定（例 昨日の 10:00-07:00 → 今日の 00:00〜07:00 部分）
      for (const t of yTimes) {
        const s = parseHHMM(t.start);
        const e = parseHHMM(t.end);
        if (e < s) {
          if (nowMin < e) return true;
        }
      }

      return false;
    }
    
    /**
     * 3段階（closed / open / soon）の営業ステータスを返す
     * soonMinutes: 閉店何分前から「閉店間近」にするか（デフォルト30分）
     */
    function getOpenStatus(openingHours, now = new Date(), soonMinutes = 30) {
      const open = isOpenNow(openingHours, now);
      if (!open) return { state: 'closed', closesAt: null, closeIn: null };

      // 「いつ閉まるか」を算出（今日枠 or 昨日からの深夜枠）
      const dayKey = getDayKey(now);
      const yesterdayKey = getDayKey(new Date(now.getTime() - 24*60*60*1000));
      const nowMin = now.getHours() * 60 + now.getMinutes();

      const todayTimes = openingHours[dayKey]?.times || [];
      const yTimes = openingHours[yesterdayKey]?.times || [];

      let closeIn = Infinity;

      // 今日の枠
      for (const t of todayTimes) {
        const s = parseHHMM(t.start);
        const e = parseHHMM(t.end);
        if (t.start === "00:00" && t.end === "24:00") return { state: 'open', closesAt: null, closeIn: null };

        if (e > s) {
          if (nowMin >= s && nowMin < e) closeIn = Math.min(closeIn, e - nowMin);
        } else if (e < s) {
          // 深夜またぎ：閉店は「翌日の end」
          // 例 10:00-07:00 で 23:00 なら、(24:00-23:00)+07:00 = 8時間
          if (nowMin >= s) {
            closeIn = Math.min(closeIn, (24 * 60 - nowMin) + e);
          }
        }
      }

      // 昨日からの深夜またぎ枠
      for (const t of yTimes) {
        const s = parseHHMM(t.start);
        const e = parseHHMM(t.end);
        if (e < s) {
          if (nowMin < e) closeIn = Math.min(closeIn, e - nowMin);
        }
      }

      // closesAt を計算（closeIn分後の時刻）
      const closesAt = closeIn < Infinity ? new Date(now.getTime() + closeIn * 60 * 1000) : null;

      if (closeIn <= soonMinutes) return { state: 'soon', closesAt, closeIn };
      return { state: 'open', closesAt, closeIn };
    }
    
    function getTodayHours(openingHours) {
      if (!openingHours) return '営業時間情報なし';
      
      const now = new Date();
      const days = ['sun', 'mon', 'tue', 'wed', 'thu', 'fri', 'sat'];
      const today = days[now.getDay()];
      
      const todayHours = openingHours[today];
      if (!todayHours || !todayHours.times || todayHours.times.length === 0) {
        return '定休日';
      }
      
      // 24時間営業判定
      if (todayHours.times.length === 1 &&
          todayHours.times[0].start === '00:00' &&
          todayHours.times[0].end === '24:00') {
        return '24時間営業';
      }
      
      return todayHours.times.map(t => `${t.start}-${t.end}`).join(', ');
    }
    
    function formatDate(dateStr) {
      const date = new Date(dateStr);
      const month = date.getMonth() + 1;
      const day = date.getDate();
      return `${month}/${day}`;
    }
    
    function formatDateDetail(dateStr) {
      const date = new Date(dateStr);
      const year = date.getFullYear();
      const month = date.getMonth() + 1;
      const day = date.getDate();
      return `${year}年${month}月${day}日`;
    }
    
    function formatDateTime(dateStr) {
      const date = new Date(dateStr);
      const year = date.getFullYear();
      const month = date.getMonth() + 1;
      const day = date.getDate();
      const hours = String(date.getHours()).padStart(2, '0');
      const minutes = String(date.getMinutes()).padStart(2, '0');
      return `${year}/${month}/${day} ${hours}:${minutes}`;
    }
    
    
