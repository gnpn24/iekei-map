    // コミュニティフィード（公開されている訪問記録の一覧）
    // 訪問記録ID一覧から、それぞれの代表写真(1枚目)のURLを取得するMapを返す
    async function fetchPhotoMapForVisits(visitIds) {
      const listMap = await fetchPhotoListMapForVisits(visitIds);
      const map = new Map();
      listMap.forEach((urls, visitId) => {
        if (urls && urls.length > 0) map.set(visitId, urls[0]);
      });
      return map;
    }

    async function fetchPhotoListMapForVisits(visitIds) {
      const map = new Map();
      if (!visitIds || visitIds.length === 0) return map;
      const { data: photoRows } = await supabaseClient
        .from('visit_photos')
        .select('visit_id, photo_url, created_at')
        .in('visit_id', visitIds)
        .order('created_at', { ascending: true });
      (photoRows || []).forEach(p => {
        if (!map.has(p.visit_id)) map.set(p.visit_id, []);
        const arr = map.get(p.visit_id);
        if (arr.length < 4) arr.push(p.photo_url);
      });
      return map;
    }

