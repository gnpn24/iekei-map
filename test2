    // 現在の天気を取得して自動挿入
    async function fetchCurrentWeather() {
      if (!currentShop || !currentShop.lat || !currentShop.lng) return;
      
      try {
        // Open-Meteo API (無料、登録不要)
        const url = `https://api.open-meteo.com/v1/forecast?latitude=${currentShop.lat}&longitude=${currentShop.lng}&current=temperature_2m,weather_code&timezone=Asia/Tokyo`;
        
        const response = await fetch(url);
        if (!response.ok) throw new Error('天気情報の取得に失敗しました');
        
        const data = await response.json();
        
        // 気温を挿入
        if (data.current && data.current.temperature_2m) {
          document.getElementById('input-temp').value = data.current.temperature_2m;
        }
        
        // 天気コードを天気に変換して挿入
        if (data.current && data.current.weather_code !== undefined) {
          const weatherText = getWeatherText(data.current.weather_code);
          document.getElementById('input-weather').value = weatherText;
        }
        
        console.log('✅ 天気情報を自動取得しました');
      } catch (error) {
        console.log('⚠️ 天気情報の取得に失敗:', error.message);
        // エラーでも何もしない（手動入力できる）
      }
    }
    
    // WMO天気コードを日本語に変換（4つの選択肢に対応）
    function getWeatherText(code) {
      // 晴れ系 (0-3)
      if (code >= 0 && code <= 2) return '晴れ';
      
      // 曇り系 (3, 45, 48)
      if (code === 3 || code === 45 || code === 48) return '曇り';
      
      // 雪系 (71-77, 85-86)
      if ((code >= 71 && code <= 77) || code === 85 || code === 86) return '雪';
      
      // 雨系 (それ以外の降水)
      if (code >= 51) return '雨';
      
      return '晴れ'; // デフォルト
    }
    
