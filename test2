    async function syncVisitsToCloud(onProgress) {
      if (!supabaseClient || !currentUser || isSyncingToCloud) return;
      isSyncingToCloud = true;
      let changed = false;
      try {
        // 進捗表示用に、未同期の件数を先に数える
        let totalUnsynced = 0;
        for (const shopId of Object.keys(visits)) {
          const logs = visits[shopId]?.logs;
          if (Array.isArray(logs)) totalUnsynced += logs.filter(l => !l._cloudSynced).length;
        }
        let doneCount = 0;
        if (onProgress) onProgress(0, totalUnsynced);

        for (const shopId of Object.keys(visits)) {
          const entry = visits[shopId];
          if (!entry) continue;

          if (entry.wantToGo || entry.favorite) {
            await supabaseClient.from('shop_status').upsert({
              user_id: currentUser.id,
              shop_id: shopId,
              want_to_go: !!entry.wantToGo,
              favorite: !!entry.favorite,
              updated_at: new Date().toISOString()
            });
          }

          const logs = entry.logs;
          if (!Array.isArray(logs)) continue;
          for (const log of logs) {
            if (log._cloudSynced) continue;
            const row = {
              user_id: currentUser.id,
              shop_id: shopId,
              visited_at: log.visitedAt ? new Date(log.visitedAt).toISOString() : null,
              rating: log.rating ?? null,
              wait_minutes: log.waitMinutes ?? null,
              temperature: log.temperature ?? null,
              weather: log.weather ?? null,
              order_text: log.order ?? null,
              options: log.options ?? null,
              noodle_firmness: log.noodleFirmness ?? null,
              flavor_intensity: log.flavorIntensity ?? null,
              oil_amount: log.oilAmount ?? null,
              memo: log.memo ?? null,
              is_public: !!log.isPublic
            };
            if (log._cloudId) {
              // 既にクラウドにある記録 → 新規作成せず更新する（編集時の重複防止）
              const { error } = await supabaseClient.from('visits').update(row).eq('id', log._cloudId);
              if (!error) {
                log._cloudSynced = true;
                changed = true;
              } else {
                console.error('クラウド同期エラー（訪問記録の更新）:', error);
              }
            } else {
              const { data, error } = await supabaseClient.from('visits').insert(row).select('id').single();
              if (!error && data) {
                log._cloudId = data.id;
                log._cloudSynced = true;
                changed = true;
              } else {
                console.error('クラウド同期エラー（訪問記録の新規作成）:', error);
              }
            }

            // 写真の同期（記録自体の同期が成功した場合のみ）
            if (log._cloudId && !log._photosSynced && log.photos && log.photos.length > 0) {
              const photoUploadOk = await syncLogPhotosToCloud(log);
              if (photoUploadOk) {
                log._photosSynced = true;
                changed = true;
              }
            }

            doneCount++;
            if (onProgress) onProgress(doneCount, totalUnsynced);
          }
        }
      } catch (e) {
        console.error('クラウド同期エラー:', e);
      } finally {
        isSyncingToCloud = false;
      }
      if (changed) {
        saveVisits(); // _cloudSyncedフラグを保存（再度syncVisitsToCloudが呼ばれても変更が無いので安全）
      }
    }

