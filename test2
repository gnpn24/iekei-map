    function selectLineageNode(shopId) {
      const shop = shops.find(s => s.id === shopId);
      if (!shop) return;
      
      document.querySelectorAll('.lineage-node.selected').forEach(n => n.classList.remove('selected'));
      document.querySelectorAll('.lineage-node-group.selected').forEach(n => n.classList.remove('selected'));
      
      const node = document.querySelector(`.lineage-node[data-id="${shopId}"]`);
      if (node) {
        node.classList.add('selected');
      } else if (shop.group) {
        // グループノードを探してselected
        const groupShops = shops.filter(s => s.group === shop.group);
        for (const gs of groupShops) {
          const gNode = document.querySelector(`.lineage-node-group[data-id="${gs.id}"]`);
          if (gNode) { gNode.classList.add('selected'); break; }
        }
      }
      
      const openStatus = getOpenStatus(shop.openingHours);
      const isRealClosed = !shop.openingHours || Object.keys(shop.openingHours).length === 0;
      
      const infoTitle = document.getElementById('lineage-info-title');
      const infoSub = document.getElementById('lineage-info-sub');
      
      if (infoTitle) {
        // 閉店店舗のみ（閉店）を表示
        infoTitle.textContent = isRealClosed ? `${shop.name}（閉店）` : shop.name;
      }
      
      if (infoSub) {
        // 状態表示
        let statusText;
        if (isRealClosed) {
          statusText = '閉店';
        } else if (openStatus.state === 'open') {
          statusText = '営業中';
        } else if (openStatus.state === 'soon') {
          statusText = '閉店間近';
        } else {
          statusText = '営業時間外';
        }
        
        infoSub.textContent = statusText;
      }
      
      // 詳細画面ボタンを表示
      const detailBtn = document.getElementById('lineage-detail-btn');
      if (detailBtn) {
        detailBtn.style.display = 'block';
        detailBtn.onclick = () => showShopDetail(shopId);
      }
    }
    
