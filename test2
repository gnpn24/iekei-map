    // 営業時間チェック関数（指定曜日・時刻）
    function isOpenAtDayTime(openingHours, dayOfWeek, timeStr) {
      if (!openingHours || dayOfWeek === '' || !timeStr) return true;
      
      console.log('🕐 isOpenAtDayTime check:', { dayOfWeek, timeStr, openingHours });
      
      const dayNames = ['sun', 'mon', 'tue', 'wed', 'thu', 'fri', 'sat'];
      const dayKey = dayNames[parseInt(dayOfWeek)];
      const dayData = openingHours[dayKey];
      
      console.log('  dayKey:', dayKey, 'dayData:', dayData);
      
      if (!dayData || !dayData.times || dayData.times.length === 0) {
        console.log('  ❌ 定休日または営業時間データなし');
        return false; // 定休日または営業時間データなし
      }
      
      // 時刻を分に変換
      const [hour, minute] = timeStr.split(':').map(Number);
      const targetMinutes = hour * 60 + minute;
      
      console.log('  targetMinutes:', targetMinutes);
      
      // 営業時間の範囲をチェック
      for (const timeRange of dayData.times) {
        const [startHour, startMinute] = timeRange.start.split(':').map(Number);
        const [endHour, endMinute] = timeRange.end.split(':').map(Number);
        
        const startMinutes = startHour * 60 + startMinute;
        let endMinutes = endHour * 60 + endMinute;
        
        // 24時を超える場合の処理（例: 23:00-01:00）
        if (endMinutes <= startMinutes) {
          endMinutes += 24 * 60;
        }
        
        console.log('  range:', timeRange.start, '-', timeRange.end, 'startMinutes:', startMinutes, 'endMinutes:', endMinutes);
        
        if (targetMinutes >= startMinutes && targetMinutes <= endMinutes) {
          console.log('  ✅ MATCH!');
          return true;
        }
      }
      
      console.log('  ❌ NO MATCH');
      return false;
    }
    
