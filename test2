    // ヘルパー関数群
    function formatPeriodHint(period) {
      const now = new Date();
      const pad = (n) => String(n).padStart(2, '0');
      const fmt = (d) => `${d.getFullYear()}/${pad(d.getMonth() + 1)}/${pad(d.getDate())}`;
      if (period === 'all') return `全期間（〜${fmt(now)}）`;
      const r = dateRangeByPeriod(period);
      return `${fmt(r.start)}〜${fmt(r.end)}`;
    }
    
    function dateRangeByPeriod(period) {
      const now = new Date();
      if (period === 'all') return { start: new Date(0), end: now };
      const days = parseInt(period);
      const start = new Date(now.getTime() - days * 24 * 60 * 60 * 1000);
      return { start, end: now };
    }
    
    function parseDateMaybe(str) {
      if (!str) return null;
      const d = new Date(str);
      return isNaN(d.getTime()) ? null : d;
    }
    
    function inRange(date, range) {
      if (!date) return false;
      return date >= range.start && date <= range.end;
    }
    
    function flattenLogs(visits) {
      const allLogs = [];
      Object.entries(visits).forEach(([shopId, visit]) => {
        if (visit.logs && visit.logs.length > 0) {
          visit.logs.forEach(log => {
            allLogs.push({ ...log, shopId });
          });
        }
      });
      return allLogs;
    }
    
    function mostCommon(map) {
      if (!map || Object.keys(map).length === 0) return null;
      let maxKey = null, maxVal = 0;
      for (const [k, v] of Object.entries(map)) {
        if (v > maxVal) { maxKey = k; maxVal = v; }
      }
      return maxKey ? { key: maxKey, count: maxVal } : null;
    }
    
    function topNCount(map, n) {
      return Object.entries(map)
        .sort((a, b) => b[1] - a[1])
        .slice(0, n);
    }
    
    function ratioBarHTML(label, count, total) {
      const pct = Math.round((count / total) * 100);
      return `
        <div class="stats-new-bar-item">
          <div class="top">
            <span>${escapeHtml(label)}</span>
            <span>${count}回 (${pct}%)</span>
          </div>
          <div class="stats-new-bar">
            <i data-width="${pct}" style="width:0%"></i>
          </div>
        </div>
      `;
    }
    
    function buildOneLiner(stats, period) {
      if (!stats || stats.bowls === 0) return 'データがありません。まず1件記録してみてください。';
      const p = period === 'all' ? '全期間' : `直近${period}日`;
      const bits = [];
      bits.push(`${p}で<b>${stats.bowls}杯</b>。`);
      if (stats.hardTop) bits.push(`麺は<b>${escapeHtml(stats.hardTop.key)}</b>が多め。`);
      if (stats.flavorTop) bits.push(`味は<b>${escapeHtml(stats.flavorTop.key)}</b>が多め。`);
      if (stats.oilTop) bits.push(`油は<b>${escapeHtml(stats.oilTop.key)}</b>が多め。`);
      if (stats.avgWait !== null) bits.push(`待ちは平均<b>${stats.avgWait}分</b>。`);
      return bits.join(' ');
    }
    
    function computeStats(visits, period) {
      const allLogs = flattenLogs(visits);
      const range = dateRangeByPeriod(period);
      
      const logs = allLogs
        .map(l => ({ ...l, _d: parseDateMaybe(l.visitedAt) }))
        .filter(l => inRange(l._d, range))
        .sort((a, b) => (b._d?.getTime() || 0) - (a._d?.getTime() || 0));
      
      const bowls = logs.length;
      
      let waitSum = 0, waitN = 0;
      const hardMap = {};
      const flavorMap = {};
      const oilMap = {};
      const shopCount = {};
      const photoCount = { yes: 0, no: 0 };
      
      for (const l of logs) {
        if (typeof l.waitMinutes === 'number' && !isNaN(l.waitMinutes)) {
          waitSum += l.waitMinutes;
          waitN++;
        }
        if (l.noodleFirmness) hardMap[l.noodleFirmness] = (hardMap[l.noodleFirmness] || 0) + 1;
        if (l.flavorIntensity) flavorMap[l.flavorIntensity] = (flavorMap[l.flavorIntensity] || 0) + 1;
        if (l.oilAmount) oilMap[l.oilAmount] = (oilMap[l.oilAmount] || 0) + 1;
        shopCount[l.shopId] = (shopCount[l.shopId] || 0) + 1;
        if (l.photo) photoCount.yes++; else photoCount.no++;
      }
      
      return {
        logs,
        bowls,
        visitedShops: Object.keys(shopCount).length,
        avgWait: waitN ? Math.round(waitSum / waitN) : null,
        hardMap,
        flavorMap,
        oilMap,
        hardTop: mostCommon(hardMap),
        flavorTop: mostCommon(flavorMap),
        oilTop: mostCommon(oilMap),
        shopCount,
        topShop: mostCommon(shopCount),
        photoCount
      };
    }
    
