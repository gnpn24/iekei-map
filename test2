    function renderShopSelectResults() {
      const query = (document.getElementById('shop-select-search').value || '').trim();
      const resultsEl = document.getElementById('shop-select-results');
      if (!resultsEl) return;

      let candidates;
      if (query) {
        candidates = (shops || []).filter(s =>
          s.name !== 'ダミー' &&
          (s.name.includes(query) || (s.nameHiragana && s.nameHiragana.includes(query)))
        ).slice(0, 20);
      } else {
        // 未入力時：訪問済みの店を優先表示（リピートが多いので）、無ければ空
        const visitedIds = Object.keys(visits).filter(id => visits[id]?.logs?.length > 0);
        candidates = visitedIds
          .map(id => (shops || []).find(s => s.id === id))
          .filter(Boolean)
          .slice(0, 10);
