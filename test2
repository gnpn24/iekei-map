    // 既存データを新形式に変換（photo → photos）
    function migratePhotoData(visits) {
      Object.values(visits).forEach(visit => {
        if (visit.logs && visit.logs.length > 0) {
          visit.logs.forEach(log => {
            // 古い形式（photo）を新形式（photos）に変換
            if (log.photo && !log.photos) {
              log.photos = [log.photo];
              delete log.photo;
            }
            // photosがない場合は空配列を設定
            if (!log.photos) {
              log.photos = [];
            }
          });
        }
      });
      return visits;
    }
    
