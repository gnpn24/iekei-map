    let feedHasMore = true;
    const FEED_PAGE_SIZE = 20;
    let feedObserver = null;

    async function loadCommunityFeed() {
      // 初回読み込み：状態をリセット
      feedPage = 0;
      feedHasMore = true;
      const listEl = document.getElementById('community-feed-list');
      if (!listEl || !supabaseClient) return;
      listEl.innerHTML = '<div style="text-align:center;color:#9ca3af;font-size:13px;padding:24px 0;">読み込み中...</div>';
      loadFeedSummary();
      await loadFeedPage(true);
    }

    async function loadFeedPage(isFirst = false) {
      if (feedIsLoading || !feedHasMore || !supabaseClient) return;
      feedIsLoading = true;

      const listEl = document.getElementById('community-feed-list');
      if (!listEl) return;

      // ローディング表示（初回以外はスピナーを末尾に追加）
      let loadingEl = null;
      if (!isFirst) {
        loadingEl = document.createElement('div');
        loadingEl.id = 'feed-loading-more';
        loadingEl.style.cssText = 'text-align:center;color:#9ca3af;font-size:13px;padding:16px 0;';
        loadingEl.textContent = '読み込み中...';
        listEl.appendChild(loadingEl);
      }

      try {
        const from = feedPage * FEED_PAGE_SIZE;
        const to = from + FEED_PAGE_SIZE - 1;

        const { data: visitRows, error } = await supabaseClient
          .from('visits')
          .select('id, shop_id, visited_at, rating, memo, order_text, options, noodle_firmness, flavor_intensity, oil_amount, weather, temperature, wait_minutes, user_id, created_at')
          .eq('is_public', true)
          .order('created_at', { ascending: false })
          .range(from, to);
        if (error) throw error;

        if (loadingEl) loadingEl.remove();

        if (isFirst) {
          listEl.innerHTML = '';
          if (!visitRows || visitRows.length === 0) {
            listEl.innerHTML = '<div style="text-align:center;color:#9ca3af;font-size:13px;padding:24px 0;">まだ公開されている記録がありません</div>';
            feedHasMore = false;
            return;
          }
        }

        // 20件未満なら次ページなし
        if (!visitRows || visitRows.length < FEED_PAGE_SIZE) {
          feedHasMore = false;
        }

        if (visitRows && visitRows.length > 0) {
          const userIds = [...new Set(visitRows.map(v => v.user_id))];
          const { data: profileRows } = await supabaseClient
            .from('profiles').select('id, display_name, avatar_url').in('id', userIds);
          const profileMap = new Map((profileRows || []).map(p => [p.id, p]));

          const visitIds = visitRows.map(v => v.id);
          const { data: likeRows } = await supabaseClient
            .from('likes').select('user_id, visit_id').in('visit_id', visitIds);
          const likeCountMap = new Map();
          const myLikedSet = new Set();
          (likeRows || []).forEach(l => {
            likeCountMap.set(l.visit_id, (likeCountMap.get(l.visit_id) || 0) + 1);
            if (currentUser && l.user_id === currentUser.id) myLikedSet.add(l.visit_id);
          });

          const photoListMap = await fetchPhotoListMapForVisits(visitIds);

          visitRows.forEach(v => {
            const profile = profileMap.get(v.user_id);
            const name = profile?.display_name || '匿名ユーザー';
            const avatarUrl = profile?.avatar_url || '';
            const shop = (typeof shops !== 'undefined' ? shops : []).find(s => s.id === v.shop_id);
            const shopName = shop?.name || v.shop_id;
            const likeCount = likeCountMap.get(v.id) || 0;
            const liked = myLikedSet.has(v.id);
            v.photo_urls = photoListMap.get(v.id) || [];
            v.photo_url = v.photo_urls[0] || null;

            const card = document.createElement('div');
            card.className = 'feed-post-card';
            communityVisitCache[v.id] = { ...v, shopName, displayName: name || '' };
            card.onclick = () => showShopDetail(v.shop_id);
            const shopMeta = [shop?.area, shop?.station].filter(Boolean).join('・');
            card.innerHTML = `
              ${feedCardBodyHtml(v, name, avatarUrl, shopName, shopMeta)}
              <div class="feed-actions">
                <button onclick="event.stopPropagation(); toggleLike('${v.id}', this)" data-liked="${liked ? '1' : '0'}" class="feed-action-cell feed-like-btn">
                  <svg class="feed-action-icon like-icon ${liked ? 'filled' : ''}" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z"></path></svg><span class="like-count">${likeCount}</span>
                </button>
                <button onclick="event.stopPropagation(); toggleFeedBookmarkUI(this)" data-saved="0" class="feed-action-cell feed-bookmark-btn" title="保存">
                  <svg class="feed-action-icon bookmark-icon" viewBox="0 0 24 24"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path></svg><span>保存</span>
                </button>
                <div class="feed-action-cell feed-relative-time">${formatFeedRelativeTime(v.created_at || v.visited_at)}</div>
              </div>
            `;
            listEl.appendChild(card);
          });

          feedPage++;
        }

        // 次ページがあれば、末尾に監視用の番兵要素を設置
        setupFeedObserver(listEl);

      } catch (e) {
        console.error('フィード読み込みエラー:', e);
        if (loadingEl) loadingEl.remove();
        if (isFirst) {
          listEl.innerHTML = '<div style="text-align:center;color:#9ca3af;font-size:13px;padding:24px 0;">読み込みに失敗しました</div>';
        }
      } finally {
        feedIsLoading = false;
      }
    }

    function setupFeedObserver(listEl) {
      // 既存の番兵を削除
      const old = document.getElementById('feed-sentinel');
      if (old) old.remove();
      if (feedObserver) { feedObserver.disconnect(); feedObserver = null; }

      if (!feedHasMore) return;

      // 末尾に番兵要素を追加
      const sentinel = document.createElement('div');
      sentinel.id = 'feed-sentinel';
      sentinel.style.height = '1px';
      listEl.appendChild(sentinel);

      feedObserver = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          loadFeedPage(false);
        }
      }, { threshold: 0.1 });
      feedObserver.observe(sentinel);
    }

    async function toggleLike(visitId, btnEl) {
      if (!supabaseClient || !currentUser) {
        await showCustomAlert('いいねするにはログインが必要です');
        return;
      }
      const liked = btnEl.dataset.liked === '1';
      const countEl = btnEl.querySelector('.like-count');
      const iconEl = btnEl.querySelector('.like-icon');
      const count = parseInt(countEl.textContent) || 0;
      try {
        if (liked) {
          await supabaseClient.from('likes').delete().eq('user_id', currentUser.id).eq('visit_id', visitId);
          btnEl.dataset.liked = '0';
          btnEl.style.color = '';
          if (iconEl) iconEl.classList.remove('filled');
          countEl.textContent = Math.max(0, count - 1);
        } else {
          await supabaseClient.from('likes').insert({ user_id: currentUser.id, visit_id: visitId });
          btnEl.dataset.liked = '1';
          btnEl.style.color = '';
          if (iconEl) iconEl.classList.add('filled');
          countEl.textContent = count + 1;
        }
      } catch (e) {
        console.error('いいねエラー:', e);
      }
    }

    // 1件の訪問記録の写真をクラウド(Storage)にアップロードし、visit_photosテーブルに登録する。
    // 最大4枚まで（容量・通信量の節約のため）。成功したらtrueを返す。
    async function syncLogPhotosToCloud(log) {
      const photosToUpload = log.photos.slice(0, 4);
      try {
        // 同じ記録の写真を一旦消してから登録し直す（再同期時の重複防止）
        await supabaseClient.from('visit_photos').delete().eq('visit_id', log._cloudId);

        for (let i = 0; i < photosToUpload.length; i++) {
          const fileName = photosToUpload[i];
          const dataUrl = await loadPhotoFromFile(fileName);
          if (!dataUrl) continue;
          const blob = await (await fetch(dataUrl)).blob();
          const path = `${currentUser.id}/${log._cloudId}/${i}.jpg`;
          const { error: uploadError } = await supabaseClient.storage
            .from('visit-photos')
            .upload(path, blob, { upsert: true, contentType: 'image/jpeg' });
          if (uploadError) {
            console.error('写真アップロードエラー:', uploadError);
            continue;
          }
          const { data: urlData } = supabaseClient.storage.from('visit-photos').getPublicUrl(path);
          await supabaseClient.from('visit_photos').insert({
            visit_id: log._cloudId,
            user_id: currentUser.id,
            photo_url: urlData.publicUrl
          });
        }
        return true;
      } catch (e) {
        console.error('写真同期エラー:', e);
        return false;
      }
    }

    // 「今すぐ同期する」ボタン：過去の未同期データ（半年分など）も含めて、進捗を表示しながら同期する
    // クラウドに保存されている自分の記録を、この端末のローカルに復元する（機種変更・別端末対策）。
    // 既に「_cloudId」が一致するものはローカルに既にあると判断してスキップ（重複防止）。
    // ===== アカウント削除 =====
    // 写真ファイルを先に削除 → 自分のアカウント(auth.users)を削除（連動して全データが自動削除される）→ ログアウト
    async function deleteAccountWithConfirm() {
      if (!supabaseClient || !currentUser) return;
      const confirmed1 = await showCustomConfirm(
        'アカウントを削除します。クラウドに保存した訪問記録・写真・プロフィール・フォロー関係など、すべてのデータが完全に削除され、元に戻せません。本当に削除しますか？'
      );
      if (!confirmed1) return;
      const confirmed2 = await showCustomConfirm('最終確認です。本当にアカウントを削除しますか？');
      if (!confirmed2) return;

      try {
        await deleteAllUserStorageFiles();
        const { error } = await supabaseClient.rpc('delete_own_account');
        if (error) throw error;
        await supabaseClient.auth.signOut();
        currentUser = null;
        currentProfile = null;
        closeAccountModal();
        updateAccountMenuSubtitle();
        updateAccountModalUI();
        await showCustomAlert('アカウントを削除しました。ご利用ありがとうございました。');
      } catch (e) {
        console.error('アカウント削除エラー:', e);
        await showCustomAlert('削除に失敗しました。時間をおいて再度お試しください。');
      }
    }

    // Storage上の自分のファイル（アイコン画像・訪問記録の写真）を削除する
    async function deleteAllUserStorageFiles() {
      try {
        await supabaseClient.storage.from('avatars').remove([`${currentUser.id}/avatar.jpg`]);
      } catch (e) {
        console.error('アイコン画像の削除エラー:', e);
