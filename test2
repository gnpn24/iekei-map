    // Data Validation（起動時チェック）
    function validateShopsData() {
      const validCategories = [
        '総本山', 
        '直系', 
        '吉村家（直系以外）',
        '本牧家', 
        '六角家', 
        '王道家', 
        '王道家（王道乃印）',
        '王道家（との丸家）',
        '武蔵家',
        '大輝家',
        '壱系', 
        '壱系（資本系）',
        'オリジナル', 
        '不明'
      ];
      const ids = new Set();
      const warnings = [];
      
      shops.forEach((shop, index) => {
        // 1. ID重複チェック
        if (ids.has(shop.id)) {
          warnings.push(`⚠️ 重複ID: "${shop.id}" (${shop.name})`);
        }
        ids.add(shop.id);
        
        // 2. 位置情報欠損チェック（【閉店】を除外）
        const isClosed = shop.name.includes('【閉店】');
        if (!isClosed && (!Number.isFinite(shop.lat) || !Number.isFinite(shop.lng))) {
          warnings.push(`⚠️ 位置情報欠損: ${shop.name} (lat: ${shop.lat}, lng: ${shop.lng})`);
        }
        
        // 3. 営業時間欠損チェック
        if (!shop.openingHours) {
          warnings.push(`⚠️ 営業時間欠損: ${shop.name}`);
        }
        
        // 4. カテゴリー表記ゆれチェック
        if (!validCategories.includes(shop.category)) {
          warnings.push(`⚠️ 不正なカテゴリー: "${shop.category}" in ${shop.name}`);
        }
      });
      
      if (warnings.length > 0) {
        console.warn('🔍 データ検証で問題を検出しました:');
        warnings.forEach(w => console.warn(w));
        console.warn(`合計: ${warnings.length}件の警告`);
      } else {
        // console.log('✅ データ検証OK: 全て正常です');
      }
      
      return warnings;
    }
    
    
    
    
    
