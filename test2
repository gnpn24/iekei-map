              name: 'ダミー',
              nameHiragana: '',
              category: shop.category,
              area: '',
              lat: null, lng: null,
              parent: shop.parent,
              group: null,
              openingHours: null,
              description: '', googleMapUrl: '', websiteUrl: '', xURL: '', note: ''
            });
          }
        }

        // 縦+N: 対象店舗の親との間にN個ダミーを挿入（親子関係を変更）
        const tateMatch = shop.position.match(/^縦\+(\d+)$/);
        if (tateMatch) {
          const count = parseInt(tateMatch[1]);
          let currentParent = shop.parent;
          const targetIdx = itemsWithDummies.findIndex(s => s.id === shop.id);
          for (let i = 0; i < count; i++) {
            const dummyId = `__dummy_tate_${shop.id}_${i}`;
            itemsWithDummies.splice(targetIdx + i, 0, {
              id: dummyId,
              name: 'ダミー',
              nameHiragana: '',
              category: shop.category,
              area: '',
              lat: null, lng: null,
              parent: currentParent,
              group: null,
              openingHours: null,
              description: '', googleMapUrl: '', websiteUrl: '', xURL: '', note: ''
            });
            currentParent = dummyId;
          }
          // 対象店舗の親を最後のダミーに変更
          const target = itemsWithDummies.find(s => s.id === shop.id);
          if (target) target.parent = currentParent;
        }

        // 縦下+N: ダミーをレベル調整に使うが線は引かない（親→子を直接つなぎダミー位置で折り曲げ）
        const tateSilentMatch = shop.position.match(/^縦下\+(\d+)$/);
        if (tateSilentMatch) {
          const count = parseInt(tateSilentMatch[1]);
          let currentParent = shop.parent;
          const targetIdx = itemsWithDummies.findIndex(s => s.id === shop.id);
          for (let i = 0; i < count; i++) {
            const dummyId = `__dummy_tate_silent_${shop.id}_${i}`;
            itemsWithDummies.splice(targetIdx + i, 0, {
              id: dummyId,
              name: 'ダミー',
              nameHiragana: '',
              category: shop.category,
              area: '',
              lat: null, lng: null,
              parent: currentParent,
              group: null,
              openingHours: null,
              description: '', googleMapUrl: '', websiteUrl: '', xURL: '', note: ''
            });
            currentParent = dummyId;
          }
          // 対象店舗の親を最後のダミーに変更
          const target = itemsWithDummies.find(s => s.id === shop.id);
          if (target) target.parent = currentParent;
        }
      });

      const levels = computeLineageLevels(itemsWithDummies, roots);

      // position: 系列 のノードは親と同じレベルに配置し、子孫も再計算
      itemsWithDummies.forEach(shop => {
        if (shop.position === '系列' && shop.parent) {
          const parentLevel = levels.get(shop.parent);
          if (parentLevel !== undefined) {
            const oldLevel = levels.get(shop.id);
            const diff = parentLevel - oldLevel;
            if (diff !== 0) {
              // このノードと全子孫のレベルをdiff分ずらす
              const adjustDescendants = (id) => {
                levels.set(id, levels.get(id) + diff);
                itemsWithDummies.forEach(s => {
                  if (s.parent === id) adjustDescendants(s.id);
                });
              };
              adjustDescendants(shop.id);
            }
          }
        }
      });

      const order = buildLineageOrder(itemsWithDummies, roots);
      
      // グループ処理: 同じgroupを持つ店舗のうち、orderに含まれる最初の1件を代表とし、残りを除外
      const groupSeen = new Set();
      const groupRepresentatives = new Map(); // groupId → 代表shopId
      const filteredOrder = order.filter(id => {
        const shop = itemsWithDummies.find(s => s.id === id) || shops.find(s => s.id === id);
        if (!shop || !shop.group) return true; // groupなしはそのまま
        if (groupSeen.has(shop.group)) return false; // 2件目以降は除外
        groupSeen.add(shop.group);
        groupRepresentatives.set(shop.group, id);
        console.log(`[GROUP] 代表: ${id} (group: ${shop.group})`);
        return true;
      });
      console.log(`[GROUP] groupRepresentatives:`, Array.from(groupRepresentatives.entries()));
      
      const maxLevel = Math.max(...Array.from(levels.values()));
      const lanes = [];
      for (let lv = 0; lv <= maxLevel; lv++) {
        lanes.push(filteredOrder.filter(id => levels.get(id) === lv));
      }
      
      const section = document.createElement('div');
      section.className = 'lineage-section';
      section.id = `lineage-section-${sectionId}`;
      section.innerHTML = `
        <div class="lineage-section-title">
          <span class="lineage-dot ${colorClass}"></span>${title}
        </div>
        <div class="lineage-section-box" data-group="${colorClass}">
          <svg class="lineage-wires"></svg>
          <div class="lineage-lanes"></div>
        </div>
      `;
      
      const lanesEl = section.querySelector('.lineage-lanes');
      
      // 全レベルを通常通り描画
      lanes.forEach((laneIds, lv) => {
        const lane = document.createElement('div');
        lane.className = 'lineage-lane';
        lane.dataset.level = lv;
        
        laneIds.forEach(id => {
          const shop = itemsWithDummies.find(s => s.id === id) || shops.find(s => s.id === id);
          if (shop) {
            // カテゴリーで色を分ける
            let nodeColor = colorClass;
            if (sectionId === '六角家系' && (shop.id === 'rokkakuya' || shop.id === 'musashiya')) {
              nodeColor = 'rokkaku';
            } else if (sectionId === 'yosh') {
              // 吉村家系セクションでは直系以外は全て薄い赤
              if (shop.category !== '直系') {
                nodeColor = 'yosh-light';
              }
            } else if (shop.category === '王道家（王道乃印）') {
              nodeColor = 'oud-light';
            } else if (shop.category === '吉村家（直系以外）') {
              nodeColor = 'yosh-light';
            } else if (['王道家', '王道家（との丸家）', '王道家（系列外）'].includes(shop.category)) {
              nodeColor = 'oud';
            } else if (shop.category === '本牧家') {
              nodeColor = 'honmoku';
            } else if (shop.category === '六角家') {
              nodeColor = 'rokkaku';
            } else if (shop.category === '武蔵家') {
              nodeColor = 'musa';
            } else if (shop.category === '野中家') {
              nodeColor = 'nonaka';
            } else if (shop.category === '大輝家') {
              nodeColor = 'taiki';
            }

            const ownSectionMap = {
              'oudouya': '王道家系',
              'honmokuya': '本牧家系',
              'rokkakuya': '六角家系',
              'musashiya': '武蔵家系',
            };
            let node;
            const isSpecialShop = ownSectionMap.hasOwnProperty(shop.id);
            if (shop.group && groupRepresentatives.get(shop.group) === shop.id && (!isSpecialShop || ownSectionMap[shop.id] === sectionId)) {
              const groupShopsCount = shops.filter(s => s.group === shop.group).length;
              // グループノードの色はカテゴリーから決定
              const groupColorMap = {
                '直系': 'yosh', '吉村家（直系以外）': 'yosh-light',
                '本牧家': 'honmoku', '六角家': 'rokkaku', '武蔵家': 'musa',
                '王道家': 'oud', '王道家（王道乃印）': 'oud-light', '王道家（との丸家）': 'oud',
                '壱系': 'isse', '壱系（資本系）': 'isse-light',
                '大輝家': 'taiki', '野中家': 'nonaka', 'オリジナル': 'oth',
              };
              const groupColor = sectionId === 'yosh' && shop.category !== '直系'
                ? 'yosh-light'
                : (groupColorMap[shop.category] || colorClass);
              if (groupShopsCount === 1) {
                // 1店舗グループは通常ノードとして描画（改行対応・エリア表示）
                node = createLineageNode(shop, nodeColor, sectionId, true);
              } else {
                node = createLineageGroupNode(shop, groupColor, sectionId);
              }
            } else {
              node = createLineageNode(shop, nodeColor, sectionId);
