        lanesEl.appendChild(lane);
      });
      
      container.appendChild(section);
      
      // DOMに追加された後に位置を調整してワイヤーを描画
      setTimeout(() => {
        const minLevel = (colorClass === 'oth') ? 1 : 2;
        adjustChildNodesPosition(section, levels, minLevel, itemsWithDummies);
        // グループの子はfilteredOrderで除外済みなのでそのまま渡す
        drawLineageWires(section, items, itemsWithDummies, levels, filteredOrder);
      }, 0);
    }
    
    // 子ノードを親の横位置に合わせる
    function adjustChildNodesPosition(section, levels, minLevel, itemsWithDummies) {
      const box = section.querySelector('.lineage-section-box');
      const boxRect = box.getBoundingClientRect();
      const nodes = section.querySelectorAll('.lineage-node, .lineage-node-group');
      
      // 各ノードの位置を記録
      const positions = new Map();
      nodes.forEach(node => {
        const rect = node.getBoundingClientRect();
        positions.set(node.dataset.id, {
          x: rect.left - boxRect.left,
          y: rect.top - boxRect.top,
          width: rect.width
        });
      });

      // 系列ノードのIDセット
      const seriesIds = new Set();
      if (itemsWithDummies) {
        itemsWithDummies.forEach(s => {
          if (s.position === '系列') seriesIds.add(s.id);
        });
      }
      
      // 指定レベル以降 + 系列ノードの子も対象
      const level2Plus = Array.from(nodes).filter(n => {
        const lv = parseInt(n.dataset.level);
        if (lv >= minLevel) return true;
        // 系列ノードの子は例外的に対象にする
        const parentId = n.dataset.parent;
        if (parentId && seriesIds.has(parentId)) return true;
        return false;
      });
      
      // 親ごとにグループ化
      const byParent = new Map();
      level2Plus.forEach(node => {
        const parentId = node.dataset.parent;
        if (!parentId) return;
        if (!byParent.has(parentId)) {
          byParent.set(parentId, []);
        }
        byParent.get(parentId).push(node);
      });
      
      // 親ごとに子を配置
      byParent.forEach((children, parentId) => {
        const parentPos = positions.get(parentId);
        if (!parentPos) return;
        
        let currentX = parentPos.x;
        
        children.forEach(node => {
          const currentPos = positions.get(node.dataset.id);
          if (currentPos) {
            const offsetX = currentX - currentPos.x;
            node.style.transform = `translateX(${offsetX}px)`;
            
            // 移動後の位置を更新（Level 3以降の配置に使う）
            positions.set(node.dataset.id, {
              x: currentX,
              y: currentPos.y,
              width: currentPos.width
            });
            
            // 次の子は現在の幅 + gap分右に配置
            currentX += currentPos.width + 18; // 18はgapX
          }
        });
      });
    }
    
    // グループポップアップを閉じる
    document.addEventListener('click', (e) => {
      if (activeGroupPopup && !e.target.closest('.lineage-node-group') && !e.target.closest('.lineage-group-popup')) {
        activeGroupPopup.classList.remove('visible');
        activeGroupPopup = null;
      }
    });
    // スクロール時にポップアップを閉じる
    document.addEventListener('scroll', (e) => {
      if (activeGroupPopup && !activeGroupPopup.contains(e.target)) {
        activeGroupPopup.classList.remove('visible');
        activeGroupPopup = null;
      }
    }, true);

    function createLineageGroupNode(shop, colorClass, sectionId) {
