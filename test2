    // APIからデータを読み込む
    async function loadShopsData() {
      const CACHE_KEY = 'iekei-shops-cache';
      const CACHE_TIMESTAMP_KEY = 'iekei-shops-timestamp';
      
      // 1. キャッシュがあれば即表示
      const cachedData = localStorage.getItem(CACHE_KEY);
      const cachedTimestamp = localStorage.getItem(CACHE_TIMESTAMP_KEY);
      
      if (cachedData) {
        try {
          shops = JSON.parse(cachedData);
          injectGroupDummyData();
          window.dataUpdatedAt = cachedTimestamp;
          updateDataTimestampDisplay();
          console.log(`📦 キャッシュから${shops.length}店舗を読み込みました`);
          console.log(`🕐 キャッシュ日時: ${new Date(cachedTimestamp).toLocaleString('ja-JP')}`);
          initializeApp();
        } catch (e) {
          console.warn('キャッシュ読み込みエラー:', e);
        }
      } else {
        // 初回読み込み時はキャッシュがないので、先に初期化（空データ）
        console.log('⚠️ キャッシュなし - API取得を待ちます');
      }
      
      // 2. 裏でAPIから最新データを取得（タイムアウト付き）
      try {
        console.log('📡 最新データを確認中...');
        
        // タイムアウト処理
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), 30000); // 30秒でタイムアウト
        
        const response = await fetch(SHOPS_API_URL, {
          signal: controller.signal,
          cache: 'no-cache'
        });
        clearTimeout(timeoutId);
        
        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        const data = await response.json();
        
        if (data.shops && data.shops.length > 0) {
          window.dataUpdatedAt = data.updatedAt;
          updateDataTimestampDisplay();
          // デバッグログ追加
          console.log('🔍 タイムスタンプ比較:');
          console.log('  data.updatedAt:', data.updatedAt);
          console.log('  cachedTimestamp:', cachedTimestamp);
          console.log('  一致?', data.updatedAt === cachedTimestamp);
          
          // 3. updatedAtが違っていたら更新
          if (data.updatedAt !== cachedTimestamp) {
            shops = data.shops;
            injectGroupDummyData();
            localStorage.setItem(CACHE_KEY, JSON.stringify(shops));
            localStorage.setItem(CACHE_TIMESTAMP_KEY, data.updatedAt);
            
            console.log(`✅ ${shops.length}店舗のデータを更新しました`);
            console.log(`🕐 更新日時: ${new Date(data.updatedAt).toLocaleString('ja-JP')}`);
            
            // トースト通知
            if (cachedData) {
              showToast('新しいデータがあります（🔄で更新）');
              // 再初期化
              initializeApp();
            } else {
              // 初回読み込み
              initializeApp();
            }
          } else {
            console.log('✅ データは最新です');
          }
        }
      } catch (error) {
        // エラーメッセージを安全に取得（AbortSignalなどのクローン不可オブジェクトを除外）
        const errorMessage = error instanceof Error ? error.message : String(error);
        console.error('❌ データ読み込みエラー:', errorMessage);
        
        // タイムアウトかネットワークエラーか判定
        if (error.name === 'AbortError') {
          console.warn('⏱️ API取得タイムアウト（10秒）');
        }
        
        // 4. 通信失敗時の処理
        if (cachedData) {
          // キャッシュがあれば黙って使う
          console.log('📦 キャッシュを使用します');
        } else {
          // キャッシュもない場合はフォールバック
          const loadingScreen = document.getElementById('loading-screen');
          if (loadingScreen) {
            loadingScreen.innerHTML = `
              <div style="font-size: 48px; margin-bottom: 20px;">❌</div>
              <div style="font-size: 18px; font-weight: 600; color: #ef4444; margin-bottom: 12px;">データ読み込みエラー</div>
              <div style="font-size: 14px; color: #6b7280; margin-bottom: 20px;">店舗データの取得に失敗しました</div>
              <div style="display: flex; gap: 12px;">
                <button onclick="location.reload()" style="
                  padding: 12px 24px;
                  background: #3b82f6;
                  color: white;
                  border: none;
                  border-radius: 8px;
                  font-size: 16px;
                  font-weight: 600;
                  cursor: pointer;
                ">再読み込み</button>
                <button onclick="useFallbackData()" style="
                  padding: 12px 24px;
                  background: #6b7280;
                  color: white;
                  border: none;
                  border-radius: 8px;
