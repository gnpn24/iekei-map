  <script>
    // ===== Android PWA高さ対策：実際の表示領域をCSS変数にセット =====
    // standaloneモードでdvhがずれて下部ナビが隠れる問題を防ぐため、
    // window.innerHeightを実測して --app-height に反映する。
    (function setupAppHeight() {
      function applyAppHeight() {
        document.documentElement.style.setProperty('--app-height', window.innerHeight + 'px');
      }
      applyAppHeight();
      window.addEventListener('resize', applyAppHeight);
      window.addEventListener('orientationchange', () => setTimeout(applyAppHeight, 150));
      window.addEventListener('pageshow', applyAppHeight);
      // visualViewport があればより正確（ソフトキーボードやバー出現に追従）
      if (window.visualViewport) {
        window.visualViewport.addEventListener('resize', applyAppHeight);
      }
      // 起動直後・リロード直後にバーの高さが確定するまで数回測り直す
      [60, 200, 500, 1000].forEach(t => setTimeout(applyAppHeight, t));
    })();

    // App Version (手動で更新)
    const APP_VERSION = "1.22.0";

    // ===== Supabase（ログイン・クラウド同期） =====
    const SUPABASE_URL = 'https://ggmfsnyhkrdoytbpvtxd.supabase.co';
    const SUPABASE_ANON_KEY = 'sb_publishable_FqdImZ_XB_PWzK3euU7O8g_gz8sLePg';
    let supabaseClient = null;
    let currentUser = null;
    let currentProfile = null; // profilesテーブルの自分の行（display_name, avatar_url, bio等）
    let isSyncingToCloud = false;

    // ===== ログイン機能の隠しフラグ（一般公開前のテスト用） =====
    // URLに ?authbeta=1 を付けてアクセス、または /test パスでアクセスすると、
    // その端末でログイン関連UIが表示されるようになる。?authbeta=0 でオフに戻せる。
    const AUTH_BETA_KEY = 'iekei-auth-beta-enabled';
    (function setupAuthBetaFlag() {
      // /test パスでのアクセスも同様にフラグON扱いにする
      if (window.location.pathname.replace(/\/+$/, '') === '/test') {
        localStorage.setItem(AUTH_BETA_KEY, '1');
      }

      const params = new URLSearchParams(window.location.search);
      if (params.has('authbeta')) {
        const val = params.get('authbeta');
        if (val === '1') localStorage.setItem(AUTH_BETA_KEY, '1');
        else if (val === '0') localStorage.removeItem(AUTH_BETA_KEY);
        // URLからパラメータを消してリロードなしで綺麗にする
        params.delete('authbeta');
        const newUrl = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
        history.replaceState({}, '', newUrl);
      }
    })();
    function isAuthBetaEnabled() {
      return localStorage.getItem(AUTH_BETA_KEY) === '1';
    }
    function applyAuthBetaVisibility() {
      const enabled = isAuthBetaEnabled();
      const display = enabled ? '' : 'none';
      const menuItem = document.getElementById('settings-account-menu-item');
      const betaArea = document.getElementById('auth-beta-area');
      const shopCommunity = document.getElementById('shop-community-section');
      if (menuItem) menuItem.style.display = display;
      if (betaArea) betaArea.style.display = display;
      if (shopCommunity) shopCommunity.style.display = display;
    }
    document.addEventListener('DOMContentLoaded', applyAuthBetaVisibility);
    // 既にDOM読み込み済みの場合（scriptが後方にある等）にも対応
    if (document.readyState === 'interactive' || document.readyState === 'complete') {
      applyAuthBetaVisibility();
    }

    try {
      supabaseClient = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
    } catch (e) {
      console.error('Supabase初期化エラー:', e);
    }

    function openAccountModal() {
      const modal = document.getElementById('account-modal');
      if (modal) {
        modal.classList.add('active');
        updateAccountModalUI();
      }
    }
    function closeAccountModal() {
      const modal = document.getElementById('account-modal');
      if (modal) modal.classList.remove('active');
    }

    async function signInWithGoogle() {
      if (!supabaseClient) return;
      const { error } = await supabaseClient.auth.signInWithOAuth({
        provider: 'google',
        options: { redirectTo: window.location.origin + window.location.pathname }
      });
      if (error) {
        console.error('Googleログインエラー:', error);
        await showCustomAlert('ログインに失敗しました。時間をおいて再度お試しください。');
      }
    }

    async function signInWithApple() {
      if (!supabaseClient) return;
      const { error } = await supabaseClient.auth.signInWithOAuth({
        provider: 'apple',
        options: { redirectTo: window.location.origin + window.location.pathname }
      });
      if (error) {
        console.error('Appleログインエラー:', error);
        await showCustomAlert('ログインに失敗しました。時間をおいて再度お試しください。');
      }
    }

    async function signOutAccount() {
      if (!supabaseClient) return;
      await supabaseClient.auth.signOut();
      currentUser = null;
      currentProfile = null;
      updateAccountMenuSubtitle();
      updateAccountModalUI();
    }

    function updateAccountMenuSubtitle() {
      const el = document.getElementById('account-menu-subtitle');
      if (el) {
        if (currentUser) {
          const name = currentProfile?.display_name || 'ログイン中';
          el.textContent = `${name} としてログイン中`;
        } else {
          el.textContent = 'ログインしてクラウド同期';
        }
      }

      // 統計タブのアカウント表示も同期して更新
      const statsOut = document.getElementById('stats-account-logged-out');
      const statsIn = document.getElementById('stats-account-logged-in');
      if (statsOut && statsIn) {
        if (currentUser) {
          statsOut.style.display = 'none';
          statsIn.style.display = 'block';
          const name = currentProfile?.display_name || 'ユーザー';
          const email = currentUser.email || '';
          const avatarUrl = currentProfile?.avatar_url || '';
          const nameEl = document.getElementById('stats-account-display-name');
          const emailEl = document.getElementById('stats-account-display-email');
          const avatarEl = document.getElementById('stats-account-avatar-img');
          const avatarEmojiEl = document.getElementById('stats-account-avatar-emoji');
          if (nameEl) nameEl.textContent = name;
          if (emailEl) emailEl.textContent = email;
          applyAvatarDisplay(avatarEl, avatarEmojiEl, avatarUrl);
        } else {
          statsOut.style.display = 'block';
          statsIn.style.display = 'none';
        }
      }
    }

    function updateAccountModalUI() {
      const loggedOutView = document.getElementById('account-logged-out');
      const loggedInView = document.getElementById('account-logged-in');
      if (!loggedOutView || !loggedInView) return;
      if (currentUser) {
        loggedOutView.style.display = 'none';
        loggedInView.style.display = 'block';
        const name = currentProfile?.display_name || 'ユーザー';
        const email = currentUser.email || '';
        const avatarUrl = currentProfile?.avatar_url || '';
        const nameEl = document.getElementById('account-display-name');
        const emailEl = document.getElementById('account-display-email');
        const avatarEl = document.getElementById('account-avatar-img');
        const avatarEmojiEl = document.getElementById('account-avatar-emoji');
        if (nameEl) nameEl.textContent = name;
        if (emailEl) emailEl.textContent = email;
        applyAvatarDisplay(avatarEl, avatarEmojiEl, avatarUrl);
      } else {
        loggedOutView.style.display = 'block';
        loggedInView.style.display = 'none';
      }
    }

    // アバター表示用のHTML文字列を生成（カード一覧などのinnerHTML組み立てで使う）
    function avatarHtml(avatarValue, sizePx) {
      if (avatarValue && avatarValue.startsWith('emoji:')) {
        const emoji = avatarValue.slice(6);
        return `<div style="width:${sizePx}px;height:${sizePx}px;border-radius:50%;background:#f3f4f6;display:flex;align-items:center;justify-content:center;font-size:${Math.round(sizePx*0.6)}px;flex-shrink:0;">${emoji}</div>`;
      } else if (avatarValue) {
        return `<img src="${avatarValue}" style="width:${sizePx}px;height:${sizePx}px;border-radius:50%;object-fit:cover;flex-shrink:0;">`;
      }
      return `<div style="width:${sizePx}px;height:${sizePx}px;border-radius:50%;background:#e5e7eb;flex-shrink:0;"></div>`;
    }

    // 訪問記録の正方形サムネイル（写真があれば表示、無ければグレーのプレースホルダー）
    function postPhotoHtml(photoUrl, extraStyle) {
      if (photoUrl) {
        return `<img src="${photoUrl}" style="width:100%;aspect-ratio:1;object-fit:cover;border-radius:8px;display:block;${extraStyle || ''}">`;
      }
      return `<div style="width:100%;aspect-ratio:1;background:#e5e7eb;border-radius:8px;${extraStyle || ''}"></div>`;
    }

    // 詳細モーダル用：写真が複数枚あればスワイプで切り替えられるストリップを作る（×ボタンも含む）
    function photoStripHtml(photoUrls, stripId, closeFnName) {
      if (!photoUrls || photoUrls.length === 0) {
        return `
          <div style="width:100%;aspect-ratio:1;background:#e5e7eb;"></div>
        `;
      }
      const slides = photoUrls.map(url =>
        `<img src="${url}" style="width:100%;flex-shrink:0;scroll-snap-align:start;display:block;background:#000;">`
      ).join('');
      const dots = photoUrls.length > 1
        ? `<div style="position:absolute;bottom:8px;left:0;right:0;display:flex;justify-content:center;gap:5px;">${photoUrls.map((_, i) =>
            `<div class="photo-strip-dot" style="width:6px;height:6px;border-radius:50%;background:${i === 0 ? 'white' : 'rgba(255,255,255,0.5)'};"></div>`
          ).join('')}</div>`
        : '';
      return `
        <div style="position:relative;background:#000;">
          <div id="${stripId}" style="display:flex;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;" onscroll="updatePhotoStripDots(this)">${slides}</div>
          ${dots}
        </div>
      `;
    }

    function updatePhotoStripDots(stripEl) {
      const idx = Math.round(stripEl.scrollLeft / stripEl.clientWidth);
      const dots = stripEl.parentElement.querySelectorAll('.photo-strip-dot');
      dots.forEach((dot, i) => {
        dot.style.background = i === idx ? 'white' : 'rgba(255,255,255,0.5)';
      });
    }

    // 訪問記録の詳細情報（ラベル＋値ボックス形式）。photo-modal・みんなの投稿詳細の両方で共通利用。
    // d = { visitedAt, rating, weather, temperature, waitMinutes, order, options, noodleFirmness, flavorIntensity, oilAmount, memo }
    function visitDetailInfoBoxesHtml(d) {
      // 日時・待ち時間・天気・気温を1行に
      const metaParts = [formatDateTime(d.visitedAt)];
      if (d.waitMinutes) metaParts.push(`待ち${d.waitMinutes}分`);
      if (d.weather || d.temperature) {
        metaParts.push(`${d.weather ? escapeHtml(d.weather) : ''}${d.temperature ? d.temperature + '°C' : ''}`);
      }

      const customizeParts = [];
      if (d.noodleFirmness) customizeParts.push(`麺:${escapeHtml(d.noodleFirmness)}`);
      if (d.flavorIntensity) customizeParts.push(`味:${escapeHtml(d.flavorIntensity)}`);
      if (d.oilAmount) customizeParts.push(`油:${escapeHtml(d.oilAmount)}`);

      return `
        <div style="font-size:14px;color:#374151;margin-bottom:4px;">${metaParts.join(' ・ ')}</div>

        ${d.rating > 0 ? `
          <div style="font-size:18px;color:#fbbf24;margin-bottom:12px;">
            ${'★'.repeat(d.rating)}${'☆'.repeat(5 - d.rating)}
          </div>
        ` : ''}

        ${d.order ? `<div style="font-size:14px;margin-bottom:2px;">🍜 ${escapeHtml(d.order)}</div>` : ''}
        ${d.options ? `<div style="font-size:14px;margin-bottom:2px;padding-left:20px;">+${escapeHtml(d.options)}</div>` : ''}
        ${customizeParts.length > 0 ? `<div style="font-size:13px;color:#9ca3af;margin-bottom:12px;">${customizeParts.join(' ')}</div>` : ''}

        ${d.memo ? `<div style="font-size:14px;line-height:1.6;color:#374151;">${escapeHtml(d.memo)}</div>` : ''}
      `;
    }

    // コミュニティ記録1件分の「注文内容・カスタマイズ・評価・メモ」部分のHTML（来店履歴と同じ表示形式）
    function visitDetailLinesHtml(v) {
      const starsStr = v.rating > 0 ? '★'.repeat(v.rating) + '☆'.repeat(5 - v.rating) : '';
      const customize = [v.noodle_firmness, v.flavor_intensity, v.oil_amount].filter(Boolean).join('/');
      return `
        ${starsStr ? `<div style="font-size:13px;color:#f59e0b;margin-bottom:2px;">${starsStr}</div>` : ''}
        ${v.order_text ? `<div style="font-size:13px;color:#1f2937;margin-bottom:2px;">${escapeHtml(v.order_text)}${v.options ? ' + ' + escapeHtml(v.options) : ''}</div>` : ''}
        ${customize ? `<div style="font-size:12px;color:#6b7280;margin-bottom:2px;">${escapeHtml(customize)}</div>` : ''}
        ${v.memo ? `<div style="font-size:13px;color:#4b5563;line-height:1.4;margin-bottom:4px;">${escapeHtml(v.memo)}</div>` : ''}
      `;
    }

    function formatDateTimeJapanese(dateStr) {
      if (!dateStr) return '';
      const date = new Date(dateStr);
      const year = date.getFullYear();
      const month = date.getMonth() + 1;
      const day = date.getDate();
      const hours = String(date.getHours()).padStart(2, '0');
      const minutes = String(date.getMinutes()).padStart(2, '0');
      return `${year}年${month}月${day}日 ${hours}:${minutes}`;
    }

    // みんなの記録カードの中身
    function formatFeedVisitMeta(v) {
      const parts = [];
      if (v.visited_at) {
        const date = new Date(v.visited_at);
        const year = date.getFullYear();
        const month = date.getMonth() + 1;
        const day = date.getDate();
        const hours = String(date.getHours()).padStart(2, '0');
        const minutes = String(date.getMinutes()).padStart(2, '0');
        parts.push(`${year}/${month}/${day} ${hours}:${minutes}`);
      }
      if (v.wait_minutes || v.wait_minutes === 0) parts.push(`待ち${v.wait_minutes}分`);
      const weatherTemp = `${v.weather ? escapeHtml(v.weather) : ''}${v.temperature || v.temperature === 0 ? escapeHtml(String(v.temperature)) + '°C' : ''}`;
      if (weatherTemp) parts.push(weatherTemp);
      return parts.join(' ・ ');
    }

    function formatFeedRelativeTime(dateStr) {
      if (!dateStr) return '';
      const date = new Date(dateStr);
      const diffMs = Date.now() - date.getTime();
      if (!Number.isFinite(diffMs)) return '';
      const diffMin = Math.max(0, Math.floor(diffMs / 60000));
      if (diffMin < 1) return 'たった今';
      if (diffMin < 60) return `${diffMin}分前`;
      const diffHour = Math.floor(diffMin / 60);
      if (diffHour < 24) return `${diffHour}時間前`;
      const diffDay = Math.floor(diffHour / 24);
      if (diffDay < 30) return `${diffDay}日前`;
      const diffMonth = Math.floor(diffDay / 30);
      if (diffMonth < 12) return `${diffMonth}ヶ月前`;
      return `${Math.floor(diffMonth / 12)}年前`;
    }

    function feedPhotosHtml(v) {
      const urls = Array.isArray(v.photo_urls) && v.photo_urls.length ? v.photo_urls : (v.photo_url ? [v.photo_url] : []);
      const limited = urls.filter(Boolean).slice(0, 4);
      if (limited.length === 0) return '';

      const gridHtml = limited.length === 1
        ? `<img src="${limited[0]}" class="feed-photo">`
        : `<div class="feed-photo-grid count-${limited.length}">${limited.map(url => `<img src="${url}">`).join('')}</div>`;
      const swipeHtml = `<div class="feed-photo-swipe-view" onscroll="updateFeedPhotoSwipeLabel(this)">${limited.map(url => `<img src="${url}">`).join('')}</div>`;
      const toggleLabel = limited.length > 1 ? `📷 ${limited.length}` : '';
      const dotsHtml = limited.length > 1
        ? `<div class="feed-photo-dots">${limited.map((_, i) => `<span class="feed-photo-dot ${i === 0 ? 'active' : ''}"></span>`).join('')}</div>`
        : '';
      return `
        <div class="feed-photo-wrap" data-photo-count="${limited.length}">
          <div class="feed-photo-grid-view">${gridHtml}</div>
          ${limited.length > 1 ? swipeHtml : ''}
          ${limited.length > 1 ? `<button class="feed-photo-toggle" type="button" onclick="event.stopPropagation(); toggleFeedPhotoMode(this)">${toggleLabel}</button>` : ''}
        </div>
        ${dotsHtml}
      `;
    }

    function toggleFeedPhotoMode(btn) {
      const wrap = btn.closest('.feed-photo-wrap');
      if (!wrap) return;
      const toSwipe = !wrap.classList.contains('is-swipe');
      wrap.classList.toggle('is-swipe', toSwipe);
      if (toSwipe) {
        const scroller = wrap.querySelector('.feed-photo-swipe-view');
        if (scroller) {
          scroller.scrollLeft = 0;
          updateFeedPhotoSwipeLabel(scroller);
        }
      } else {
        const count = wrap.dataset.photoCount || btn.textContent.replace(/[^0-9]/g, '') || '';
        btn.textContent = count ? `📷 ${count}` : '▦';
        updateFeedPhotoDots(wrap, 1);
      }
    }

    function updateFeedPhotoDots(wrap, activeIndex) {
      if (!wrap) return;
      const dotsWrap = wrap.nextElementSibling;
      if (!dotsWrap || !dotsWrap.classList.contains('feed-photo-dots')) return;
      dotsWrap.querySelectorAll('.feed-photo-dot').forEach((dot, i) => {
        dot.classList.toggle('active', i === activeIndex - 1);
      });
    }

    function updateFeedPhotoSwipeLabel(scroller) {
      const wrap = scroller.closest('.feed-photo-wrap');
      const btn = wrap ? wrap.querySelector('.feed-photo-toggle') : null;
      if (!btn) return;
      const count = parseInt(wrap.dataset.photoCount || '0', 10) || scroller.children.length || 1;
      const index = Math.min(count, Math.max(1, Math.round(scroller.scrollLeft / scroller.clientWidth) + 1));
      btn.textContent = `${index} / ${count}`;
      updateFeedPhotoDots(wrap, index);
    }

    function toggleFeedBookmarkUI(btnEl) {
      const saved = btnEl.dataset.saved === '1';
      const iconEl = btnEl.querySelector('.bookmark-icon');
      btnEl.dataset.saved = saved ? '0' : '1';
      if (iconEl) iconEl.classList.toggle('filled', !saved);
    }

    // 投稿カード本体。1-2行目はユーザー＋訪問情報、右に「マップで見る」。3-4行目は店名＋場所、右に評価。
    function feedCardBodyHtml(v, name, avatarUrl, shopName, shopMeta) {
      const ratingLabel = v.rating > 0 ? Number(v.rating).toFixed(1) : '';
      const orderLine = [v.order_text, v.options].filter(Boolean).join(' / ');
      const metaLine = shopMeta || '';
      const visitMeta = formatFeedVisitMeta(v);

      return `
        <div class="feed-post-main">
          <div class="feed-post-top">
            <div onclick="event.stopPropagation(); openUserProfile('${v.user_id}')" class="feed-user-avatar">
              ${avatarHtml(avatarUrl, 44)}
            </div>
            <div class="feed-top-text">
              <div onclick="event.stopPropagation(); openUserProfile('${v.user_id}')" class="feed-user-name" style="cursor:pointer;">${escapeHtml(name)}</div>
              ${visitMeta ? `<div class="feed-user-meta">${visitMeta}</div>` : ''}
            </div>
            <div class="feed-post-map-area">
              ${shopName ? `<button class="feed-map-btn" onclick="event.stopPropagation(); openShopOnMap('${v.shop_id}')">📍 マップで見る</button>` : ''}
            </div>
          </div>

          <div class="feed-shop-row">
            <div class="feed-shop-text">
              ${shopName ? `<div onclick="event.stopPropagation(); closeCommunityVisitDetailModal(); showShopDetail('${v.shop_id}')" class="feed-shop-name">${escapeHtml(shopName)}</div>` : ''}
              ${metaLine ? `<div class="feed-shop-meta">${escapeHtml(metaLine)}</div>` : ''}
            </div>
            ${ratingLabel ? `<div class="feed-rating-pill">★ ${ratingLabel}</div>` : ''}
          </div>

          ${feedPhotosHtml(v)}

          ${orderLine ? `<div class="feed-order-line">🍜 ${escapeHtml(orderLine)}</div>` : ''}
          ${v.memo ? `<div class="feed-memo">${escapeHtml(v.memo)}</div>` : ''}
        </div>
      `;
    }

    // コミュニティの投稿（クラウド上の訪問記録）の詳細表示。
    // タップした行のデータをキャッシュしておき、IDで引き出して表示する（読み取り専用・編集削除なし）。
    let communityVisitCache = {};

    // ===== 統合モーダル（投稿詳細 ↔ プロフィール） =====
    // 現在どのビューを表示中か（'visit' or 'profile'）と、
    // 投稿詳細から開いた場合のvisitIdを保持する
    let communityModalCurrentView = null;
    let communityModalCurrentVisitId = null;
    let communityModalCurrentUserId = null;

    function closeCommunityModal() {
      document.getElementById('community-modal').classList.remove('active');
      communityModalCurrentView = null;
      communityModalCurrentVisitId = null;
      communityModalCurrentUserId = null;
    }

    // 後方互換性のためのエイリアス（フィードカードのevent.stopPropagation()等で参照）
    function closeCommunityVisitDetailModal() { closeCommunityModal(); }
    function closeUserProfileModal() { closeCommunityModal(); }

    // ヘッダーのユーザー名ボタン：投稿詳細⇔プロフィールを切り替える
    function toggleCommunityModalView() {
      if (communityModalCurrentView === 'visit') {
        // 投稿詳細 → プロフィールへ
        showCommunityProfileView(communityModalCurrentUserId);
      } else if (communityModalCurrentView === 'profile' && communityModalCurrentVisitId) {
        // プロフィール → 投稿詳細へ戻る
        showCommunityVisitView(communityModalCurrentVisitId);
      }
    }

    function setModalHeader(name, canToggle) {
      const btn = document.getElementById('community-modal-user-btn');
      if (!btn) return;
      if (canToggle && communityModalCurrentView === 'profile' && communityModalCurrentVisitId) {
        btn.innerHTML = `<span style="font-size:18px;margin-right:2px;">←</span>${escapeHtml(name)}`;
      } else if (canToggle && communityModalCurrentView === 'visit') {
        btn.innerHTML = `${escapeHtml(name)}<span style="font-size:12px;color:#9ca3af;margin-left:4px;">▶ プロフィール</span>`;
      } else {
        btn.textContent = name;
        btn.style.cursor = 'default';
      }
    }

    // 投稿詳細ビューを表示
    async function showCommunityVisitDetail(visitId) {
      communityModalCurrentVisitId = visitId;
      document.getElementById('community-modal').classList.add('active');
      showCommunityVisitView(visitId);
    }

    async function showCommunityVisitView(visitId) {
      communityModalCurrentView = 'visit';
      communityModalCurrentVisitId = visitId;

      document.getElementById('community-visit-view').style.display = 'block';
      document.getElementById('community-profile-view').style.display = 'none';

      const v = communityVisitCache[visitId];
      if (!v) return;

      communityModalCurrentUserId = v.user_id;
      setModalHeader(v.displayName || '', true);

      const shop = (typeof shops !== 'undefined' ? shops : []).find(s => s.id === v.shop_id);
      const shopName = v.shopName || shop?.name || currentShop?.name || v.shop_id || '';

      const infoHTML = `
        <div style="font-size:20px;font-weight:700;margin-bottom:12px;">${escapeHtml(shopName)}</div>
        ${visitDetailInfoBoxesHtml({
          visitedAt: v.visited_at,
          rating: v.rating,
          weather: v.weather,
          temperature: v.temperature,
          waitMinutes: v.wait_minutes,
          order: v.order_text,
          options: v.options,
          noodleFirmness: v.noodle_firmness,
          flavorIntensity: v.flavor_intensity,
          oilAmount: v.oil_amount,
          memo: v.memo
        })}
      `;

      document.getElementById('community-visit-detail-info').innerHTML = infoHTML;
      document.getElementById('community-visit-shop-btn').onclick = () => {
        closeCommunityModal();
        showShopDetail(v.shop_id);
      };

      // 写真（まず1枚表示、全件取得後に差し替え）
      document.getElementById('community-visit-detail-photo-area').innerHTML =
        photoStripHtml(v.photo_url ? [v.photo_url] : [], 'community-visit-img-strip', 'closeCommunityModal');

      try {
        if (supabaseClient) {
          const { data: photoRows } = await supabaseClient
            .from('visit_photos')
            .select('photo_url, created_at')
            .eq('visit_id', visitId)
            .order('created_at', { ascending: true });
          const urls = (photoRows || []).map(p => p.photo_url);
          if (urls.length > 0) {
            document.getElementById('community-visit-detail-photo-area').innerHTML =
              photoStripHtml(urls, 'community-visit-img-strip', 'closeCommunityModal');
          }
        }
      } catch (e) {
        console.error('写真一覧の取得エラー:', e);
      }
    }

    // プロフィールビューを表示
    async function openUserProfile(userId) {
      communityModalCurrentUserId = userId;
      document.getElementById('community-modal').classList.add('active');
      showCommunityProfileView(userId);
    }

    async function showCommunityProfileView(userId) {
      communityModalCurrentView = 'profile';
      communityModalCurrentUserId = userId;

      document.getElementById('community-visit-view').style.display = 'none';
      document.getElementById('community-profile-view').style.display = 'block';
      document.getElementById('user-profile-loading').style.display = 'block';
      document.getElementById('user-profile-content').style.display = 'none';

      try {
        const { data: profile, error: profileError } = await supabaseClient
          .from('profiles')
          .select('id, display_name, avatar_url, bio')
          .eq('id', userId)
          .single();
        if (profileError) throw profileError;

        const { count: followerCount } = await supabaseClient
          .from('follows').select('*', { count: 'exact', head: true }).eq('following_id', userId);
        const { count: followingCount } = await supabaseClient
          .from('follows').select('*', { count: 'exact', head: true }).eq('follower_id', userId);

        let isFollowing = false;
        if (currentUser && currentUser.id !== userId) {
          const { data: followRow } = await supabaseClient
            .from('follows').select('follower_id')
            .eq('follower_id', currentUser.id).eq('following_id', userId)
            .maybeSingle();
          isFollowing = !!followRow;
        }

        const { data: visitRows } = await supabaseClient
          .from('visits')
          .select('id, shop_id, visited_at, rating, memo, order_text, options, noodle_firmness, flavor_intensity, oil_amount, weather, temperature, wait_minutes, created_at')
          .eq('user_id', userId)
          .eq('is_public', true)
          .order('created_at', { ascending: false })
          .limit(50);

        const photoListMap = await fetchPhotoListMapForVisits((visitRows || []).map(v => v.id));
        (visitRows || []).forEach(v => {
          v.photo_urls = photoListMap.get(v.id) || [];
          v.photo_url = v.photo_urls[0] || null;
        });

        const name = profile?.display_name || 'ユーザー';
        setModalHeader(name, !!communityModalCurrentVisitId);
        renderUserProfile({ profile, followerCount: followerCount || 0, followingCount: followingCount || 0, isFollowing, visitRows: visitRows || [], userId });
      } catch (e) {
        console.error('プロフィール取得エラー:', e);
        document.getElementById('user-profile-loading').textContent = '読み込みに失敗しました';
      }
    }

    function renderUserProfile({ profile, followerCount, followingCount, isFollowing, visitRows, userId }) {
      document.getElementById('user-profile-loading').style.display = 'none';
      document.getElementById('user-profile-content').style.display = 'block';

      const name = profile?.display_name || 'ユーザー';
      const bio = profile?.bio || '';
      document.getElementById('user-profile-name').textContent = name;
      document.getElementById('user-profile-bio').textContent = bio;
      document.getElementById('user-profile-follow-counts').textContent = `フォロー中 ${followingCount} ・ フォロワー ${followerCount}`;
      applyAvatarDisplay(
        document.getElementById('user-profile-avatar-img'),
        document.getElementById('user-profile-avatar-emoji'),
        profile?.avatar_url
      );

      // フォローボタン（自分自身の場合は表示しない）
      const followBtnWrap = document.getElementById('user-profile-follow-btn-wrap');
      if (currentUser && currentUser.id !== userId) {
        followBtnWrap.innerHTML = `
          <button id="user-profile-follow-btn" data-following="${isFollowing ? '1' : '0'}" data-user-id="${userId}"
            onclick="toggleFollow(this)" style="
            padding:9px 20px;border-radius:9px;font-size:13px;font-weight:700;cursor:pointer;
            border:${isFollowing ? '1.5px solid #e5e7eb' : 'none'};
            background:${isFollowing ? 'white' : '#111827'};
            color:${isFollowing ? '#374151' : 'white'};
          ">${isFollowing ? 'フォロー中' : 'フォローする'}</button>
        `;
      } else {
        followBtnWrap.innerHTML = '';
      }

      // 訪れたお店一覧（Instagram風のグリッド表示）
      const listEl = document.getElementById('user-profile-visits-list');
      if (!visitRows || visitRows.length === 0) {
        listEl.innerHTML = '<div style="text-align:center;color:#9ca3af;font-size:13px;padding:16px 0;">公開されている記録がありません</div>';
        return;
      }
      listEl.style.display = 'grid';
      listEl.style.gridTemplateColumns = 'repeat(3, 1fr)';
      listEl.style.gap = '4px';
      listEl.innerHTML = '';
      visitRows.forEach(v => {
        const shop = (typeof shops !== 'undefined' ? shops : []).find(s => s.id === v.shop_id);
        const shopName = shop?.name || v.shop_id;
        communityVisitCache[v.id] = { ...v, shopName, displayName: name || '' };
        const cell = document.createElement('div');
        cell.style.cursor = 'pointer';
        cell.innerHTML = postPhotoHtml(v.photo_url, 'border-radius:4px;');
        cell.onclick = () => { closeCommunityModal(); showShopDetail(v.shop_id); };
        listEl.appendChild(cell);
      });
    }

    async function toggleFollow(btnEl) {
      if (!supabaseClient || !currentUser) {
        await showCustomAlert('フォローするにはログインが必要です');
        return;
      }
      const targetUserId = btnEl.dataset.userId;
      const isFollowing = btnEl.dataset.following === '1';
      try {
        if (isFollowing) {
          await supabaseClient.from('follows').delete()
            .eq('follower_id', currentUser.id).eq('following_id', targetUserId);
          btnEl.dataset.following = '0';
          btnEl.textContent = 'フォローする';
          btnEl.style.background = '#111827';
          btnEl.style.color = 'white';
          btnEl.style.border = 'none';
        } else {
          await supabaseClient.from('follows').insert({ follower_id: currentUser.id, following_id: targetUserId });
          btnEl.dataset.following = '1';
          btnEl.textContent = 'フォロー中';
          btnEl.style.background = 'white';
          btnEl.style.color = '#374151';
          btnEl.style.border = '1.5px solid #e5e7eb';
        }
        // フォロワー数の表示も更新
        const { count: followerCount } = await supabaseClient
          .from('follows').select('*', { count: 'exact', head: true }).eq('following_id', targetUserId);
        const { count: followingCount } = await supabaseClient
          .from('follows').select('*', { count: 'exact', head: true }).eq('follower_id', targetUserId);
        const countsEl = document.getElementById('user-profile-follow-counts');
        if (countsEl) countsEl.textContent = `フォロー中 ${followingCount || 0} ・ フォロワー ${followerCount || 0}`;
      } catch (e) {
        console.error('フォロー処理エラー:', e);
        await showCustomAlert('処理に失敗しました。もう一度お試しください。');
      }
    }

    // クラウド同期：訪問記録（テキスト情報）と行きたい/お気に入りをSupabaseに反映
    // ※ 写真のクラウド同期は今後対応予定。今はテキスト情報のみ同期します。
    // 店舗詳細：その店の「みんなの記録」（公開されている他ユーザーの訪問記録）
    async function loadShopCommunityVisits(shopId) {
      const listEl = document.getElementById('shop-community-list');
      if (!listEl || !supabaseClient) return;
      listEl.innerHTML = '<div style="text-align:center;color:#9ca3af;font-size:13px;padding:16px 0;">読み込み中...</div>';
      try {
        const { data: visitRows, error } = await supabaseClient
          .from('visits')
          .select('id, visited_at, rating, memo, order_text, options, noodle_firmness, flavor_intensity, oil_amount, weather, temperature, wait_minutes, user_id, created_at')
          .eq('shop_id', shopId)
          .eq('is_public', true)
          .order('created_at', { ascending: false })
          .limit(30);
        if (error) throw error;

        if (!visitRows || visitRows.length === 0) {
          listEl.innerHTML = '<div style="text-align:center;color:#9ca3af;font-size:13px;padding:16px 0;">まだ公開されている記録がありません</div>';
          return;
        }

        const userIds = [...new Set(visitRows.map(v => v.user_id))];
        const { data: profileRows } = await supabaseClient
          .from('profiles')
          .select('id, display_name, avatar_url')
          .in('id', userIds);
        const profileMap = new Map((profileRows || []).map(p => [p.id, p]));

        const visitIds = visitRows.map(v => v.id);
        const { data: likeRows } = await supabaseClient
          .from('likes')
