    function compressImage(dataUrl, callback) {
      const img = new Image();
      img.onload = () => {
        // 長辺を800pxに制限（より積極的なリサイズ）
        const MAX_SIZE = 800;
        let width = img.width;
        let height = img.height;

        console.log(`📸 元の画像サイズ: ${width}x${height}`);

        if (width > height && width > MAX_SIZE) {
          height = Math.round((height * MAX_SIZE) / width);
          width = MAX_SIZE;
        } else if (height > MAX_SIZE) {
          width = Math.round((width * MAX_SIZE) / height);
          height = MAX_SIZE;
        }

        console.log(`📸 リサイズ後: ${width}x${height}`);

        // Canvas で圧縮
        const canvas = document.createElement('canvas');
        canvas.width = width;
        canvas.height = height;
        const ctx = canvas.getContext('2d');
        ctx.drawImage(img, 0, 0, width, height);

        // JPEG 0.5品質で出力（より積極的な圧縮、200KB前後を目標）
        let quality = 0.5;
        let compressedDataUrl = canvas.toDataURL('image/jpeg', quality);

        // ファイルサイズを計算（Base64のバイト数）
        let sizeInBytes = Math.round((compressedDataUrl.length - 'data:image/jpeg;base64,'.length) * 0.75);
        let sizeInKB = Math.round(sizeInBytes / 1024);

        // 500KBを超える場合は品質をさらに下げる
        if (sizeInKB > 500) {
          quality = 0.3;
          compressedDataUrl = canvas.toDataURL('image/jpeg', quality);
          sizeInBytes = Math.round((compressedDataUrl.length - 'data:image/jpeg;base64,'.length) * 0.75);
          sizeInKB = Math.round(sizeInBytes / 1024);
          console.log(`📸 再圧縮（品質30%）: ${sizeInKB}KB`);
        }

        console.log(`📸 最終サイズ: ${sizeInKB}KB（品質${Math.round(quality * 100)}%）`);

        callback(compressedDataUrl);
      };
      img.src = dataUrl;
    }
    
    // 写真をファイルとして保存してファイル名を取得
    async function savePhotoToFile(base64Data) {
      return new Promise((resolve) => {
        window.onPhotoSaved = (fileName) => {
          console.log('📸 写真をファイルとして保存しました:', fileName);
          resolve(fileName);
        };

        if (isNativeApp) {
          // ネイティブアプリの場合、Swift側に保存
          window.webkit.messageHandlers.savePhoto.postMessage(base64Data);
        } else {
          // Web版の場合、Base64のまま返す（互換性のため）
          resolve(base64Data);
        }
      });
    }

    // 写真をファイルから読み込む
    async function loadPhotoFromFile(fileName) {
      return new Promise((resolve) => {
        // Base64データの場合はそのまま返す（旧データとの互換性）
        if (fileName && fileName.startsWith('data:image')) {
          resolve(fileName);
          return;
        }
        // クラウドから復元した写真（実URL）の場合もそのまま返す
        if (fileName && (fileName.startsWith('http://') || fileName.startsWith('https://'))) {
          resolve(fileName);
          return;
        }

        // ユニークなコールバック名を生成
        const callbackId = `onPhotoLoaded_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
        
        window[callbackId] = (base64Data) => {
          console.log('📸 写真をファイルから読み込みました:', fileName);
          delete window[callbackId]; // コールバックをクリーンアップ
          resolve(base64Data);
        };

        if (isNativeApp) {
          // ネイティブアプリの場合、Swift側から読み込み
