        'yosh': '#c62828', 'yosh-light': '#ef5350',
        'honmoku': '#1976d2', 'rokkaku': '#43a047',
        'oud': '#f9a825', 'oud-light': '#fbc02d',
        'musa': '#f57c00', 'nonaka': '#f57c00',
        'taiki': '#00acc1', 'isse': '#8e24aa', 'oth': '#455a64'
      };
      const dotColor = colorMap[colorClass] || '#666';
      const popup = document.createElement('div');
      popup.className = 'lineage-group-popup';
      popup.innerHTML = `
        <div class="lineage-group-popup-title">${groupLabelHtml}（${count}店舗）</div>
        <div class="lineage-group-popup-columns${(window.innerWidth < 600 && groupShops.length > 6) ? ' two-col' : ''}">
          ${(() => {
            const isMobile = window.innerWidth < 600;
            const ROWS_PER_COL = isMobile
              ? (groupShops.length <= 6 ? groupShops.length : Math.ceil(groupShops.length / 2))
              : 4;
            const cols = [];
            for (let i = 0; i < groupShops.length; i += ROWS_PER_COL) {
              const col = groupShops.slice(i, i + ROWS_PER_COL);
