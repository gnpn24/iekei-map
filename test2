            else if (shop.id === 'rokkakuya') groupJumpLink = `<span class="lineage-jump" data-target="六角家系" style="font-size:10px;margin-left:4px;color:#000000;cursor:pointer;user-select:none;">[→六角家系]</span>`;
            else if (shop.id === 'musashiya') groupJumpLink = `<span class="lineage-jump" data-target="武蔵家系" style="font-size:10px;margin-left:4px;color:#000000;cursor:pointer;user-select:none;">[→武蔵家系]</span>`;
