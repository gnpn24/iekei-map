    function renderHours() {
      const days = ['mon', 'tue', 'wed', 'thu', 'fri', 'sat', 'sun'];
      const dayNames = { mon: '月', tue: '火', wed: '水', thu: '木', fri: '金', sat: '土', sun: '日' };
      
      // 現在の日時
      const now = new Date();
      const currentHour = now.getHours();
      const currentMinute = now.getMinutes();
      const systemDayIndex = now.getDay() === 0 ? 6 : now.getDay() - 1; // 月=0, 日=6
      
      // 深夜帯（0:00-5:00）で前日の営業時間が24時を超える場合、前日を「今日」とする
      let actualToday = days[systemDayIndex];
      
      if (currentHour >= 0 && currentHour < 5) {
        const yesterdayIndex = systemDayIndex === 0 ? 6 : systemDayIndex - 1;
        const yesterday = days[yesterdayIndex];
        const yesterdayData = currentShop.openingHours[yesterday];
        
        // 前日の営業時間が24時を超えているかチェック
        if (yesterdayData && yesterdayData.times.length > 0) {
          for (const time of yesterdayData.times) {
            const endHour = parseInt(time.end.split(':')[0]);
            const endMinute = parseInt(time.end.split(':')[1]);
            
            // 終了時刻が24時以降（例: 25:00 = 翌1:00）
            if (endHour >= 24) {
              const actualEndHour = endHour - 24;
              const currentTotalMinutes = currentHour * 60 + currentMinute;
              const endTotalMinutes = actualEndHour * 60 + endMinute;
              
              // 現在時刻が前日の営業時間内
              if (currentTotalMinutes <= endTotalMinutes) {
                actualToday = yesterday;
                break;
              }
            }
          }
        }
      }
      
      const today = actualToday;
      
      // 今日の営業時間のみ
      const todayData = currentShop.openingHours[today];
      const isClosed = todayData.times.length === 0;
      const todayHTML = `
        <div class="hours-row today">
          <span class="hours-day" style="color: #3b82f6; font-weight: 600;">${dayNames[today]}曜日</span>
          <span class="hours-time" style="color: ${isClosed ? '#ef4444' : '#3b82f6'}; font-weight: 600;">
            ${isClosed ? '定休日' : todayData.times.map(t => `${t.start}-${t.end}`).join(', ')}
          </span>
        </div>
      `;
      
      // 全曜日の営業時間
      const allHoursHTML = days.map(day => {
        const dayData = currentShop.openingHours[day];
        const isToday = day === today;
        const isClosed = dayData.times.length === 0;
        
        return `
          <div class="hours-row ${isToday ? 'today' : ''}">
            <span class="hours-day" style="${isToday ? 'color: #3b82f6; font-weight: 600;' : ''}">${dayNames[day]}曜日</span>
            <span class="hours-time" style="${isClosed ? 'color: #ef4444;' : ''} ${isToday ? 'color: #3b82f6; font-weight: 600;' : ''}">
              ${isClosed ? '定休日' : dayData.times.map(t => `${t.start}-${t.end}`).join(', ')}
            </span>
          </div>
        `;
      }).join('');
      
      document.getElementById('detail-hours-today').innerHTML = todayHTML;
      document.getElementById('detail-hours-all').innerHTML = allHoursHTML;
    }
    
